FROM node:20-slim

# Metadata
LABEL com.my-ez-cli.project="my-ez-cli"
LABEL com.my-ez-cli.tool="claude"
LABEL com.my-ez-cli.version="1.0.0"
LABEL org.opencontainers.image.source="https://github.com/DavidCardoso/my-ez-cli"
LABEL org.opencontainers.image.description="Claude Code CLI for My Ez CLI"
LABEL org.opencontainers.image.licenses="MIT"

ARG TZ
ENV TZ="${TZ:-Europe/Amsterdam}"

# Install basic development tools and iptables/ipset
RUN apt-get update && apt-get install -y --no-install-recommends \
    less \
    git \
    procps \
    sudo \
    fzf \
    zsh \
    man-db \
    unzip \
    gnupg2 \
    gh \
    curl \
    iptables \
    ipset \
    iproute2 \
    dnsutils \
    aggregate \
    jq \
    neovim \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Setup global npm directory for non-root user
RUN mkdir -p /usr/local/share/npm-global && \
    chown -R node:node /usr/local/share/npm-global

# Create workspace and config directories
RUN mkdir -p /workspace /home/node/.claude && \
    touch /home/node/.claude.json && \
    chown -R node:node /workspace /home/node/.claude /home/node/.claude.json

WORKDIR /workspace

# Set up non-root user
USER node

# Configure npm global path
ENV NPM_CONFIG_PREFIX=/usr/local/share/npm-global
ENV PATH=$PATH:/usr/local/share/npm-global/bin

# Set the default shell to zsh rather than sh
ENV SHELL=/bin/zsh

# Set the default editor and visual
ENV EDITOR=nvim
ENV VISUAL=nvim

# Install Claude Code CLI
ARG CLAUDE_CODE_VERSION=latest
RUN npm install -g @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}

# Copy and set up firewall script
COPY init-firewall.sh /usr/local/bin/
USER root
RUN chmod +x /usr/local/bin/init-firewall.sh && \
  echo "node ALL=(root) NOPASSWD: /usr/local/bin/init-firewall.sh" > /etc/sudoers.d/node-firewall && \
  chmod 0440 /etc/sudoers.d/node-firewall

# Create firewall config directory and copy domain lists (generated by build script)
RUN mkdir -p /etc/mec-firewall
COPY firewall/github_meta_endpoints.txt /etc/mec-firewall/
COPY firewall/dns_resolve_domains.txt /etc/mec-firewall/

# Run build-time domain resolution (bakes resolved IPs into image)
COPY resolve-domains.sh /tmp/
RUN chmod +x /tmp/resolve-domains.sh && /tmp/resolve-domains.sh && rm /tmp/resolve-domains.sh

# Copy entrypoint script
COPY entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/entrypoint.sh && \
  echo "node ALL=(root) NOPASSWD: /usr/local/bin/init-firewall.sh" >> /etc/sudoers.d/node-firewall

# Set up non-root user
USER node

# Entry point
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
