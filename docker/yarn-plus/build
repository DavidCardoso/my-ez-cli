#!/bin/bash
set -e

# Image configuration
IMAGE_REPO=ghcr.io/my-ez-cli
IMAGE_TOOL=yarn-plus

# Auto-detect platform if not set
if [ -z "$PLATFORM" ]; then
    # Detect local architecture
    ARCH=$(uname -m)
    case "$ARCH" in
        x86_64)  PLATFORM=linux/amd64 ;;
        aarch64|arm64) PLATFORM=linux/arm64 ;;
        *)       PLATFORM=linux/amd64 ;;
    esac
    echo "PLATFORM not set, auto-detected: ${PLATFORM}"
fi

# Build configuration via env vars
if [ -z "$IMAGE_TAG" ]; then
    IMAGE_TAG=latest
    echo "IMAGE_TAG not set, using default: ${IMAGE_TAG}"
fi

if [ -z "$MEC_YARN_PLUS_VERSION" ]; then
    MEC_YARN_PLUS_VERSION=1.22.22
    echo "MEC_YARN_PLUS_VERSION not set, using default: ${MEC_YARN_PLUS_VERSION}"
fi

if [ -z "$MEC_YARN_PLUS_BASE_VERSION" ]; then
    MEC_YARN_PLUS_BASE_VERSION=22
    echo "MEC_YARN_PLUS_BASE_VERSION not set, using default: ${MEC_YARN_PLUS_BASE_VERSION}"
fi

# Build options (use --load for local single-platform builds, --push for CI multi-platform)
BUILD_OPTS="--platform ${PLATFORM}"

if [ "$CI" = "true" ]; then
    # CI mode: multi-platform build with push (if enabled)
    echo "CI mode detected"
    if [ "$PUSH" = "true" ]; then
        BUILD_OPTS="${BUILD_OPTS} --push"
    fi
else
    # Local mode: single-platform build with load
    BUILD_OPTS="${BUILD_OPTS} --load"
fi

echo "=========================================================="
echo "Building '${IMAGE_REPO}/${IMAGE_TOOL}:${IMAGE_TAG}'..."
echo "Platform: ${PLATFORM}"
echo "Yarn version: ${MEC_YARN_PLUS_VERSION} (Node base: ${MEC_YARN_PLUS_BASE_VERSION})"
echo "Build options: ${BUILD_OPTS}"
echo "=========================================================="

_extra_tags=""
if [ "$MEC_YARN_PLUS_VERSION" != "latest" ]; then
    _extra_tags="--tag ${IMAGE_REPO}/${IMAGE_TOOL}:${MEC_YARN_PLUS_VERSION}-node${MEC_YARN_PLUS_BASE_VERSION}"
fi

docker buildx build \
    ${BUILD_OPTS} \
    --build-arg MEC_YARN_PLUS_BASE_VERSION=${MEC_YARN_PLUS_BASE_VERSION} \
    --tag ${IMAGE_REPO}/${IMAGE_TOOL}:${IMAGE_TAG} \
    ${_extra_tags} \
    .
