#!/bin/sh
set -e

# Image configuration
IMAGE_REPO=davidcardoso/my-ez-cli
IMAGE_TOOL=cdktf

# Auto-detect platform if not set
if [ -z "$PLATFORM" ]; then
    # Detect local architecture
    ARCH=$(uname -m)
    case "$ARCH" in
        x86_64)  PLATFORM=linux/amd64 ;;
        aarch64|arm64) PLATFORM=linux/arm64 ;;
        *)       PLATFORM=linux/amd64 ;;
    esac
    echo "PLATFORM not set, auto-detected: ${PLATFORM}"
fi

# Build configuration via env vars
if [ -z "$IMAGE_TAG" ]; then
    IMAGE_TAG=latest
    echo "IMAGE_TAG not set, using default: ${IMAGE_TAG}"
fi

if [ -z "$TF_VERSION" ]; then
    TF_VERSION=1.13.0
    echo "TF_VERSION not set, using default: ${TF_VERSION}"
fi

if [ -z "$CDKTF_VERSION" ]; then
    CDKTF_VERSION=latest
    echo "CDKTF_VERSION not set, using default: ${CDKTF_VERSION}"
fi

if [ -z "$PYTHON_VERSION" ]; then
    PYTHON_VERSION=3.12
    echo "PYTHON_VERSION not set, using default: ${PYTHON_VERSION}"
fi

# Build options (use --load for local single-platform builds, --push for CI multi-platform)
BUILD_OPTS="--platform ${PLATFORM}"

if [ "$CI" = "true" ]; then
    # CI mode: multi-platform build with push (if enabled)
    echo "CI mode detected"
    if [ "$PUSH" = "true" ]; then
        BUILD_OPTS="${BUILD_OPTS} --push"
    fi
else
    # Local mode: single-platform build with load
    BUILD_OPTS="${BUILD_OPTS} --load"
fi

echo "=========================================================="
echo "Building '${IMAGE_REPO}:${IMAGE_TOOL}-${IMAGE_TAG}'..."
echo "Platform: ${PLATFORM}"
echo "Build options: ${BUILD_OPTS}"
echo "=========================================================="

docker buildx build \
    ${BUILD_OPTS} \
    --build-arg TF_VERSION=${TF_VERSION} \
    --build-arg CDKTF_VERSION=${CDKTF_VERSION} \
    --build-arg PYTHON_VERSION=${PYTHON_VERSION} \
    --tag ${IMAGE_REPO}:${IMAGE_TOOL}-${IMAGE_TAG} \
    .
