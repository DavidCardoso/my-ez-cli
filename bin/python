#!/bin/bash
set -e

# Source common utilities (works with symlinks)
SCRIPT_DIR="$(cd "$(dirname "$([ -L "$0" ] && readlink "$0" || echo "$0")")" && pwd)"
MEC_BASE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
. "${MEC_BASE_DIR}/bin/utils/common.sh"

# Check Docker availability
check_docker

IMAGE=${IMAGE:-"$MEC_IMAGE_PYTHON"}
WORKDIR=/app

# Container naming and labeling
CONTAINER_NAME=$(get_container_name "python")
CONTAINER_LABELS=$(get_container_labels "python" "$IMAGE")

# Setup logging (if enabled)
setup_logging "python" "$IMAGE" "python ${*}"

# Build docker command
DOCKER_CMD="docker run -i $(get_tty_flag) --rm \
    --name $CONTAINER_NAME \
    $CONTAINER_LABELS \
    --volume $PWD:$WORKDIR \
    --workdir $WORKDIR \
    --entrypoint python \
    $IMAGE $(printf '%q ' "$@")"

# Execute with AI analysis (error detection for Python scripts)
exec_with_ai "$DOCKER_CMD"
