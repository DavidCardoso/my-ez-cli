#!/bin/bash
set -e

# Source common utilities (works with symlinks)
SCRIPT_DIR="$(cd "$(dirname "$([ -L "$0" ] && readlink "$0" || echo "$0")")" && pwd)"
MEC_BASE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# override default image
export IMAGE="node:22-alpine"

# import & run the local default node script
. "${MEC_BASE_DIR}/bin/node"
