# _mec_logs_stats
# Show aggregate execution statistics
_mec_logs_stats() {
    local log_dir="${MEC_LOG_DIR:-${HOME}/.my-ez-cli/logs}"

    if [ ! -d "$log_dir" ]; then
        echo "No log directory found at $log_dir"
        return 0
    fi

    local all_files
    all_files=$(find "$log_dir" -name "*.json" ! -name "*.bak" 2>/dev/null)

    if [ -z "$all_files" ]; then
        echo "No log files found."
        return 0
    fi

    if command -v python3 >/dev/null 2>&1; then
        python3 - "$log_dir" <<'PYEOF'
import sys, os, json, glob
from datetime import datetime

log_dir = sys.argv[1]
files = glob.glob(os.path.join(log_dir, "**", "*.json"), recursive=True)
files = [f for f in files if not f.endswith(".bak")]

total = 0
failures = 0
ai_count = 0
tool_stats = {}  # tool -> {runs, failures, total_secs}

for f in files:
    try:
        with open(f) as fh:
            data = json.load(fh)
    except Exception:
        continue

    total += 1
    tool = data.get("tool", "unknown")
    exec_data = data.get("execution", {})
    exit_code = exec_data.get("exit_code", 0)
    start_time = exec_data.get("start_time", "")
    end_time = exec_data.get("end_time", "")

    ai_sidecar = f.replace('/logs/', '/ai-analyses/')
    if os.path.exists(ai_sidecar):
        ai_count += 1

    if exit_code != 0:
        failures += 1

    duration_secs = None
    if start_time and end_time:
        try:
            fmt = "%Y-%m-%dT%H:%M:%S"
            s = start_time.split(".")[0].rstrip("Z")
            e = end_time.split(".")[0].rstrip("Z")
            delta = datetime.strptime(e, fmt) - datetime.strptime(s, fmt)
            duration_secs = delta.total_seconds()
        except Exception:
            pass

    if tool not in tool_stats:
        tool_stats[tool] = {"runs": 0, "failures": 0, "total_secs": 0, "timed": 0}
    tool_stats[tool]["runs"] += 1
    if exit_code != 0:
        tool_stats[tool]["failures"] += 1
    if duration_secs is not None:
        tool_stats[tool]["total_secs"] += duration_secs
        tool_stats[tool]["timed"] += 1

success_rate = int((total - failures) / total * 100) if total > 0 else 0

print("Execution Stats")
print("---------------")
print(f"  Total runs:     {total}")
print(f"  Failures:       {failures}  ({100 - success_rate}%)")
print()
print(f"  {'Tool':<14} {'Runs':>5}  {'Failures':>8}  {'Avg Duration':>12}")
print(f"  {'-'*14} {'-'*5}  {'-'*8}  {'-'*12}")
for tool, stats in sorted(tool_stats.items(), key=lambda x: -x[1]["runs"]):
    avg_dur = "-"
    if stats["timed"] > 0:
        avg_dur = str(int(stats["total_secs"] / stats["timed"])) + "s"
    print(f"  {tool:<14} {stats['runs']:>5}  {stats['failures']:>8}  {avg_dur:>12}")
print()
print(f"  AI analyses:   {ai_count} saved")
PYEOF
    else
        # Fallback: basic counts without python3
        local total failures ai_count
        total=$(echo "$all_files" | wc -l | tr -d ' ')
        failures=$(echo "$all_files" | while IFS= read -r f; do
            [ -f "$f" ] || continue
            ec=$(awk -F'"exit_code"[[:space:]]*:[[:space:]]*' '{print $2}' "$f" 2>/dev/null | awk -F'[^0-9-]' '{print $1; exit}')
            [ -n "$ec" ] && [ "$ec" != "0" ] && echo "1"
        done | wc -l | tr -d ' ')
        ai_count=$(echo "$all_files" | while IFS= read -r f; do
            [ -f "$f" ] || continue
            ai_f=$(echo "$f" | sed 's|/logs/|/ai-analyses/|')
            [ -f "$ai_f" ] && echo "1"
        done | wc -l | tr -d ' ')

        echo "Execution Stats"
        echo "---------------"
        echo "  Total runs:   $total"
        echo "  Failures:     $failures"
        echo "  AI analyses:  $ai_count saved"
        echo ""
        echo "  (Install python3 for per-tool breakdown)"
    fi
}

# ----------------------------------------------------------------------------
# Claude Firewall Commands
# ----------------------------------------------------------------------------

mec_claude_firewall() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    local GITHUB_META_KEY="ai.claude.firewall.github_meta_endpoints"
    local DNS_DOMAINS_KEY="ai.claude.firewall.dns_resolve_domains"

    case "$subcmd" in
        status)
            echo "Claude Firewall Status"
            echo "----------------------"
            local enabled
            enabled=$(config_get_default "ai.claude.firewall.enabled" "false")
            echo "  Enabled: $enabled"
            echo ""
            echo "  GitHub meta endpoints:"
            config_get_list_default "$GITHUB_META_KEY" | while IFS= read -r item; do
                echo "    - $item"
            done
            echo ""
            echo "  DNS resolve domains:"
            config_get_list_default "$DNS_DOMAINS_KEY" | while IFS= read -r item; do
                echo "    - $item"
            done
            ;;
        list)
            echo "GitHub meta endpoints:"
            config_get_list_default "$GITHUB_META_KEY" | while IFS= read -r item; do
                echo "  - $item"
            done
            echo ""
            echo "DNS resolve domains:"
            config_get_list_default "$DNS_DOMAINS_KEY" | while IFS= read -r item; do
                echo "  - $item"
            done
            ;;
        add)
            local list_type="${1:-}"
            local domain="${2:-}"
            if [ -z "$list_type" ] || [ -z "$domain" ]; then
                echo "Usage: mec claude firewall add <github-meta|dns> <domain>" >&2
                return 1
            fi
            case "$list_type" in
                github-meta)
                    _firewall_add_domain "$GITHUB_META_KEY" "$domain"
                    echo "Added '$domain' to github-meta endpoints."
                    echo "Run 'mec claude firewall rebuild' to apply changes."
                    ;;
                dns)
                    _firewall_add_domain "$DNS_DOMAINS_KEY" "$domain"
                    echo "Added '$domain' to DNS resolve domains."
                    echo "Run 'mec claude firewall rebuild' to apply changes."
                    ;;
                *)
                    echo "Unknown list type: $list_type" >&2
                    echo "Use 'github-meta' or 'dns'" >&2
                    return 1
                    ;;
            esac
            ;;
        remove)
            local list_type="${1:-}"
            local domain="${2:-}"
            if [ -z "$list_type" ] || [ -z "$domain" ]; then
                echo "Usage: mec claude firewall remove <github-meta|dns> <domain>" >&2
                return 1
            fi
            case "$list_type" in
                github-meta)
                    _firewall_remove_domain "$GITHUB_META_KEY" "$domain"
                    echo "Removed '$domain' from github-meta endpoints."
                    echo "Run 'mec claude firewall rebuild' to apply changes."
                    ;;
                dns)
                    _firewall_remove_domain "$DNS_DOMAINS_KEY" "$domain"
                    echo "Removed '$domain' from DNS resolve domains."
                    echo "Run 'mec claude firewall rebuild' to apply changes."
                    ;;
                *)
                    echo "Unknown list type: $list_type" >&2
                    echo "Use 'github-meta' or 'dns'" >&2
                    return 1
                    ;;
            esac
            ;;
        enable)
            config_set "ai.claude.firewall.enabled" "true"
            echo "Claude firewall enabled."
            echo "Run 'mec claude firewall rebuild' to build the image with resolved IPs."
            ;;
        disable)
            config_set "ai.claude.firewall.enabled" "false"
            echo "Claude firewall disabled."
            ;;
        rebuild)
            echo "Rebuilding Claude Code Docker image with updated domain resolution..."
            local build_script="${BASE_DIR}/docker/claude/build"
            if [ ! -f "$build_script" ]; then
                echo "ERROR: Build script not found: $build_script" >&2
                return 1
            fi
            bash "$build_script"
            echo "Rebuild complete. IPs are now baked into the image."
            ;;
        help|--help|-h)
            cat <<'EOF'
Usage: mec claude firewall <command> [arguments]

Commands:
  status                              Show firewall enabled state and domain lists
  list                                List all configured domains
  add <github-meta|dns> <domain>      Add a domain to the firewall allow list
  remove <github-meta|dns> <domain>   Remove a domain from the allow list
  enable                              Enable the container firewall
  disable                             Disable the container firewall
  rebuild                             Rebuild Docker image with fresh IP resolution
  help                                Show this help message

Domain list types:
  github-meta   GitHub API endpoints (IPs fetched via api.github.com/meta CIDR ranges)
  dns           Domains resolved via DNS at Docker build time

Notes:
  - IPs are resolved at 'docker build' time and baked into the image
  - Run 'mec claude firewall rebuild' after any domain changes
  - Firewall requires NET_ADMIN capability (added automatically when enabled)

Examples:
  mec claude firewall status
  mec claude firewall list
  mec claude firewall add dns custom.example.com
  mec claude firewall remove dns custom.example.com
  mec claude firewall enable
  mec claude firewall rebuild
EOF
            ;;
        *)
            echo "Unknown firewall command: $subcmd" >&2
            echo "Run 'mec claude firewall help' for usage information" >&2
            return 1
            ;;
    esac
}

# ----------------------------------------------------------------------------
# Setup / Install / Uninstall Commands
# ----------------------------------------------------------------------------

mec_setup() {
    local subcmd="${1:-}"
    shift 2>/dev/null || true

    case "$subcmd" in
        "")
            exec "${BASE_DIR}/setup.sh"
            ;;
        show)
            exec "${BASE_DIR}/setup.sh" status
            ;;
        help|--help|-h)
            cat <<'EOF'
Usage: mec setup [subcommand]

Subcommands:
  (none)   Open interactive setup TUI
  show     Show installation status
  help     Show this help message

Examples:
  mec setup
  mec setup show
EOF
            ;;
        *)
            echo "Unknown setup subcommand: $subcmd" >&2
            echo "Run 'mec setup help' for usage information" >&2
            return 1
            ;;
    esac
}

mec_install() {
    if [ $# -eq 0 ]; then
        echo "Usage: mec install <tool> [tool2 ...]" >&2
        return 1
    fi
    exec "${BASE_DIR}/setup.sh" install "$@"
}

mec_uninstall() {
    if [ $# -eq 0 ]; then
        echo "Usage: mec uninstall <tool> [tool2 ...]" >&2
        return 1
    fi
    exec "${BASE_DIR}/setup.sh" uninstall "$@"
}

# ----------------------------------------------------------------------------
# Main Dispatch
# ----------------------------------------------------------------------------

COMMAND="${1:-help}"

case "$COMMAND" in
    config)
        shift
        mec_config "${1:---help}" "${@:2}"
        ;;
    ai)
        shift
        mec_ai "${1:---help}" "${@:2}"
        ;;
    logs)
        shift
        mec_logs "${1:---help}" "${@:2}"
        ;;
    claude)
        shift
        # Intercept 'mec claude firewall' before passing to bin/claude
        if [ "${1:-}" = "firewall" ]; then
            shift
            mec_claude_firewall "$@"
        else
            exec "$SCRIPT_DIR/claude" "$@"
        fi
        ;;
    setup)
        shift
        mec_setup "$@"
        ;;
    install)
        shift
        mec_install "$@"
        ;;
    uninstall)
        shift
        mec_uninstall "$@"
        ;;
    version|--version|-v)
        show_version
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo "Unknown command: $COMMAND" >&2
        echo "Run 'mec help' for usage information" >&2
        exit 1
        ;;
esac
