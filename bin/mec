#!/bin/bash
# ============================================================================
# My Ez CLI - Main Command
# ============================================================================
# Main entry point for my-ez-cli command-line interface
# Version: 1.0.0
# ============================================================================

set -e

# Get script directory (works with symlinks)
get_script_dir() {
    SCRIPT="$0"
    if [ -L "$SCRIPT" ]; then
        if command -v readlink >/dev/null 2>&1; then
            if readlink -f "$SCRIPT" >/dev/null 2>&1; then
                SCRIPT=$(readlink -f "$SCRIPT")
            else
                SCRIPT=$(readlink "$SCRIPT")
            fi
        fi
    fi
    dirname "$SCRIPT"
}

SCRIPT_DIR=$(get_script_dir)
BASE_DIR=$(cd "$SCRIPT_DIR/.." && pwd)

# Source utilities
. "$SCRIPT_DIR/utils/common.sh"

# Source config manager
if [ -f "${BASE_DIR}/bin/utils/config-manager.sh" ]; then
    . "${BASE_DIR}/bin/utils/config-manager.sh"
fi

# ----------------------------------------------------------------------------
# Commands
# ----------------------------------------------------------------------------

show_version() {
    echo "my-ez-cli version ${MEC_VERSION}"
}

show_help() {
    # Use bold section headers when writing to a terminal
    local _b="" _r=""
    if [ -t 1 ]; then
        _b=$(printf '\033[1m')
        _r=$(printf '\033[0m')
    fi

    printf '%s\n' "My Ez CLI — Docker-based Development Tools"
    printf '%s\n' ""
    printf '%s\n' "${_b}USAGE${_r}"
    printf '%s\n' "  mec <command> [arguments]"
    printf '%s\n' "  mec <command> --help"
    printf '%s\n' ""
    printf '%s\n' "${_b}CORE COMMANDS${_r}"
    printf '%s\n' "  install <tool...>   Install one or more tools"
    printf '%s\n' "  uninstall <tool...> Uninstall one or more tools"
    printf '%s\n' "  setup               Interactive setup TUI"
    printf '%s\n' "  list                List all tools and their active image"
    printf '%s\n' "  update [tool] [image:tag] Pull latest images (or pin to image:tag)"
    printf '%s\n' "  reset <tool>        Remove image pin for a public tool"
    printf '%s\n' ""
    printf '%s\n' "${_b}MANAGEMENT COMMANDS${_r}"
    printf '%s\n' "  config              Manage configuration"
    printf '%s\n' "  telemetry           Session telemetry (enable/disable/status)"
    printf '%s\n' "  logs                Log file management (output capture)"
    printf '%s\n' "  purge               Purge log and AI analysis files"
    printf '%s\n' "  doctor              Health check"
    printf '%s\n' ""
    printf '%s\n' "${_b}AI & DASHBOARD${_r}"
    printf '%s\n' "  ai *                AI analysis (enable, status, logs, analyze)"
    printf '%s\n' "  dashboard *         Web dashboard (start, stop, status, open, rebuild)"
    printf '%s\n' "  claude              Run Claude Code interactively"
    printf '%s\n' "  claude firewall *   Manage Claude Code container firewall"
    printf '%s\n' ""
    printf '%s\n' "${_b}TOOLS${_r}"
    printf '%s\n' "  aws                 AWS CLI"
    printf '%s\n' "  aws-get-session-token  AWS session token helper"
    printf '%s\n' "  aws-sso             AWS SSO login"
    printf '%s\n' "  aws-sso-cred        AWS SSO credential provider"
    printf '%s\n' "  gcloud              Google Cloud CLI"
    printf '%s\n' "  gcloud-login        Google Cloud interactive login"
    printf '%s\n' "  node, node20/22/24  Node.js (default: node22)"
    printf '%s\n' "  npm, npm20/22       npm"
    printf '%s\n' "  npx, npx20/22       npx"
    printf '%s\n' "  playwright          Playwright browser testing"
    printf '%s\n' "  promptfoo           PromptFoo AI evaluation"
    printf '%s\n' "  promptfoo-server    PromptFoo server"
    printf '%s\n' "  python              Python"
    printf '%s\n' "  serverless          Serverless Framework"
    printf '%s\n' "  speedtest           Network speed test"
    printf '%s\n' "  terraform           Terraform"
    printf '%s\n' "  yarn, yarn20/22     Yarn"
    printf '%s\n' "  yarn-berry          Yarn Berry (v2+)"
    printf '%s\n' "  yarn-plus           Yarn with git, curl, jq"
    printf '%s\n' ""
    printf '%s\n' "${_b}OTHER COMMANDS${_r}"
    printf '%s\n' "  version             Show version"
    printf '%s\n' "  help                Show this help"
    printf '%s\n' ""
    printf '%s\n' "Run 'mec <command> --help' for subcommand details."
    printf '%s\n' ""
    printf '%s\n' "${_b}EXAMPLES${_r}"
    printf '%s\n' "  mec install node terraform"
    printf '%s\n' "  mec node --version"
    printf '%s\n' "  mec terraform --version"
    printf '%s\n' "  mec ai status"
    printf '%s\n' "  mec dashboard start"
    printf '%s\n' "  mec logs list --tool node"
    printf '%s\n' "  mec claude firewall status"
}


# ----------------------------------------------------------------------------
# AI Commands
# ----------------------------------------------------------------------------

mec_ai() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    case "$subcmd" in
        status)
            echo "AI Integration Status"
            echo "---------------------"

            # Check config
            local ai_enabled ai_label
            ai_enabled=$(config_get_default "ai.enabled" "false")
            [ "$ai_enabled" = "true" ] && ai_label="enabled" || ai_label="disabled"
            echo "  AI:            $ai_label"

            # Check middleware (I/O filtering)
            if docker image inspect "$MEC_IMAGE_AI_SERVICE" >/dev/null 2>&1; then
                echo "  Middleware:    available"
            else
                echo "  Middleware:    not available (image not found)"
            fi

            # Check Claude Code
            if docker image inspect "$MEC_IMAGE_CLAUDE" >/dev/null 2>&1; then
                echo "  Claude Code:   available"
            else
                echo "  Claude Code:   not available (image not found)"
            fi

            # Show Claude wrapper symlink name
            local claude_link=""
            local claude_target
            if [ -L "/usr/local/bin/claude" ]; then
                claude_target=$(readlink -f "/usr/local/bin/claude" 2>/dev/null || readlink "/usr/local/bin/claude")
                if [[ "$claude_target" == */bin/claude ]]; then
                    claude_link="claude  (/usr/local/bin/claude → bin/claude)"
                fi
            fi
            if [ -z "$claude_link" ] && [ -L "/usr/local/bin/mec-claude" ]; then
                claude_link="mec claude or mec-claude  (/usr/local/bin/mec-claude → bin/claude)"
            fi
            if [ -z "$claude_link" ]; then
                claude_link="not installed (use 'bin/claude' or 'mec claude' directly)"
            fi
            echo "  Claude wrapper: $claude_link"

            # Check telemetry state
            local logging_enabled
            logging_enabled=$(config_get_default "telemetry.enabled" "true")
            if [ "$logging_enabled" = "true" ]; then
                echo "  Telemetry:     enabled"
            else
                echo "  Telemetry:     disabled  (AI analysis requires telemetry — run 'mec telemetry enable')"
            fi

            # Show Claude execution settings
            local claude_model claude_max_tokens claude_effort_level
            claude_model=$(config_get_default "ai.claude.model" "sonnet")
            claude_max_tokens=$(config_get_default "ai.claude.max_output_tokens" "8096")
            claude_effort_level=$(config_get_default "ai.claude.effort_level" "medium")
            echo "  Model:         $claude_model"
            echo "  Max tokens:    $claude_max_tokens"
            echo "  Effort level:  $claude_effort_level (opus only)"

            # Check auth
            if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
                echo "  Auth:          ANTHROPIC_API_KEY set"
            elif [ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
                echo "  Auth:          CLAUDE_CODE_OAUTH_TOKEN set"
            elif [ -d "${HOME}/.claude" ] && [ -f "${HOME}/.claude/.credentials.json" ]; then
                echo "  Auth:          configured (~/.claude/) — interactive use only"
            else
                echo "  Auth:          not configured (set ANTHROPIC_API_KEY or CLAUDE_CODE_OAUTH_TOKEN)"
            fi
            ;;
        enable)
            config_set "ai.enabled" "true"
            echo "AI integration enabled."
            ;;
        disable)
            config_set "ai.enabled" "false"
            echo "AI integration disabled."
            ;;
        test)
            echo "Testing Claude Code availability..."

            # Test Docker image
            if ! docker image inspect "$MEC_IMAGE_CLAUDE" >/dev/null 2>&1; then
                echo "FAIL: Claude Code Docker image not found." >&2
                echo "  Pull it with: docker pull $MEC_IMAGE_CLAUDE" >&2
                return 1
            fi
            echo "  Docker image: OK"

            # Test auth credential
            if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
                echo "  Auth:          ANTHROPIC_API_KEY set"
            elif [ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
                echo "  Auth:          CLAUDE_CODE_OAUTH_TOKEN set"
            else
                echo "WARN: No auth credential set." >&2
                echo "  For API key:    export ANTHROPIC_API_KEY=sk-ant-..." >&2
                echo "  For OAuth token: export CLAUDE_CODE_OAUTH_TOKEN=sk-..." >&2
            fi

            # Test Claude Code runs
            local version_output
            version_output=$(docker run --rm \
                "$MEC_IMAGE_CLAUDE" \
                --version 2>/dev/null || echo "")

            if [ -n "$version_output" ]; then
                echo "  Claude Code: $version_output"
                echo "All checks passed."
            else
                echo "WARN: Could not verify Claude Code version." >&2
                echo "  The image exists but may need updating." >&2
            fi
            ;;
        last)
            _mec_ai_last
            ;;
        show)
            _mec_ai_show "$@"
            ;;
        logs)
            _mec_ai_logs "$@"
            ;;
        analyze)
            local _input="$1"
            if [ -z "$_input" ]; then
                echo "Usage: mec ai analyze <log-file|session-id>" >&2
                return 1
            fi

            local log_file
            if [ -f "$_input" ]; then
                log_file="$_input"
            else
                log_file=$(log_find_by_session_id "$_input")
                if [ -z "$log_file" ]; then
                    echo "Error: Not a file and no session found for: $_input" >&2
                    return 1
                fi
            fi

            # Check Claude Code availability
            if ! docker image inspect "$MEC_IMAGE_CLAUDE" >/dev/null 2>&1; then
                echo "Error: Claude Code Docker image not found." >&2
                echo "  Pull it with: docker pull $MEC_IMAGE_CLAUDE" >&2
                return 1
            fi

            if [ -z "${ANTHROPIC_API_KEY:-}" ] && [ -z "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
                echo "Error: No auth credential set." >&2
                echo "  API key:     export ANTHROPIC_API_KEY=sk-ant-..." >&2
                echo "  OAuth token: export CLAUDE_CODE_OAUTH_TOKEN=sk-..." >&2
                return 1
            fi

            echo "Analyzing: $log_file"
            echo ""
            _mec_ai_notify "$log_file"

            # Snapshot env vars before backgrounding (same pattern as trigger_ai_analysis)
            local _api_key="${ANTHROPIC_API_KEY:-}"
            local _oauth_token="${CLAUDE_CODE_OAUTH_TOKEN:-}"
            local _ai_enabled="${MEC_AI_ENABLED:-}"
            local _home="${HOME}"
            local _pwd="${PWD}"

            ( ANTHROPIC_API_KEY="$_api_key" \
              CLAUDE_CODE_OAUTH_TOKEN="$_oauth_token" \
              MEC_AI_ENABLED="$_ai_enabled" \
              HOME="$_home" \
              PWD="$_pwd" \
              run_claude_analysis "$log_file" ) &
            disown
            ;;
        help|--help|-h)
            local _b="" _r=""
            if [ -t 1 ]; then _b=$(printf '\033[1m'); _r=$(printf '\033[0m'); fi
            printf '%s\n' "${_b}USAGE${_r}"
            printf '%s\n' "  mec ai <command> [arguments]"
            printf '%s\n' ""
            printf '%s\n' "${_b}COMMANDS${_r}"
            printf '%s\n' "  status              Show AI integration status"
            printf '%s\n' "  enable              Enable AI integration"
            printf '%s\n' "  disable             Disable AI integration"
            printf '%s\n' "  test                Test Claude Code availability"
            printf '%s\n' "  last                Show the most recent AI analysis"
            printf '%s\n' "  show <session_id>   Show a specific session by ID"
            printf '%s\n' "  logs [--last N]     List recent sessions with AI status (default: last 20)"
            printf '%s\n' "  analyze <log-file|session-id>  Analyze a log file with Claude Code"
            printf '%s\n' "  help                Show this help"
            printf '%s\n' ""
            printf '%s\n' "${_b}REQUIREMENTS${_r} (one of)"
            printf '%s\n' "  ANTHROPIC_API_KEY        Anthropic API key (Console credits)"
            printf '%s\n' "  CLAUDE_CODE_OAUTH_TOKEN  Long-lived OAuth token (Claude.ai subscription)"
            printf '%s\n' ""
            printf '%s\n' "${_b}CONFIGURATION${_r} (set with 'mec config set <key> <value>')"
            printf '%s\n' "  ai.claude.model              Model for analysis (default: sonnet)"
            printf '%s\n' "                               Accepted: sonnet, haiku, opus, or full model ID"
            printf '%s\n' "  ai.claude.max_output_tokens  Max tokens in response (default: 8096)"
            printf '%s\n' "                               Range: 1024–64000; lower = shorter, cheaper"
            printf '%s\n' "  ai.claude.effort_level       Effort level for opus only (default: medium)"
            printf '%s\n' "                               Accepted: low, medium, high"
            printf '%s\n' "  ai.dashboard.port            Dashboard port (default: 4242)"
            printf '%s\n' ""
            printf '%s\n' "${_b}EXAMPLES${_r}"
            printf '%s\n' "  mec ai status"
            printf '%s\n' "  mec ai enable"
            printf '%s\n' "  mec ai test"
            printf '%s\n' "  mec ai last"
            printf '%s\n' "  mec ai logs --last 5"
            printf '%s\n' "  mec ai analyze \$MEC_HOME/logs/node/2026-01-01_12-00-00.json"
            printf '%s\n' "  mec ai analyze mec-node-1774880478"
            printf '%s\n' "  mec config set ai.claude.model haiku"
            ;;
        *)
            echo "Unknown ai command: $subcmd" >&2
            echo "Run 'mec ai help' for usage information" >&2
            return 1
            ;;
    esac
}

# _mec_ai_print_session <log_file>
# Print session info + AI analysis for a given log file.
_mec_ai_print_session() {
    local log_file="$1"

    local session_id tool start_time exit_code
    session_id=$(grep '"session_id"' "$log_file" 2>/dev/null | sed 's/.*"session_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)
    tool=$(grep '"tool"' "$log_file" 2>/dev/null | sed 's/.*"tool"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)
    start_time=$(grep '"start_time"' "$log_file" 2>/dev/null | sed 's/.*"start_time"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1 | sed 's/T/ /; s/\.[0-9]*//')
    exit_code=$(grep '"exit_code"' "$log_file" 2>/dev/null | sed 's/.*"exit_code"[[:space:]]*:[[:space:]]*\(-\{0,1\}[0-9][0-9]*\).*/\1/' | head -1)

    local ai_file ai_status result
    ai_file=$(echo "$log_file" | sed 's|/logs/|/ai-analyses/|')

    local claude_session_id="" exec_time_ms="" tokens_in="" tokens_out=""
    if [ -f "$ai_file" ]; then
        if command -v python3 >/dev/null 2>&1; then
            result=$(python3 -c "
import json
with open('$ai_file') as f:
    d = json.load(f)
items = sorted(d.get('analyses', {}).items(), key=lambda kv: kv[1].get('timestamp', ''))
print(items[-1][1].get('result', '') if items else '', end='')
" 2>/dev/null)
            claude_session_id=$(python3 -c "
import json
with open('$ai_file') as f:
    d = json.load(f)
items = sorted(d.get('analyses', {}).items(), key=lambda kv: kv[1].get('timestamp', ''))
print(items[-1][0] if items else '', end='')
" 2>/dev/null)
        else
            result=$(grep '"result"' "$ai_file" 2>/dev/null | sed 's/.*"result"[[:space:]]*:[[:space:]]*"\(.*\)"/\1/' | head -1 | sed 's/\\n/\n/g; s/\\t/\t/g')
        fi
        # Extract AI metrics from sidecar (pretty-printed JSON — one field per line)
        exec_time_ms=$(grep '"execution_time_ms"' "$ai_file" 2>/dev/null \
            | sed 's/.*"execution_time_ms"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/' \
            | tail -1)
        tokens_in=$(grep '"input"' "$ai_file" 2>/dev/null \
            | sed 's/.*"input"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/' \
            | tail -1)
        tokens_out=$(grep '"output"' "$ai_file" 2>/dev/null \
            | sed 's/.*"output"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/' \
            | tail -1)
        if [ -n "$result" ]; then
            ai_status="done"
        else
            ai_status="pending"
        fi
    else
        ai_status="none"
    fi

    local dashboard_url
    dashboard_url=$(_mec_dashboard_url)

    echo "Session:   ${session_id:-unknown}"
    echo "Tool:      ${tool:-unknown}"
    echo "Timestamp: ${start_time:-unknown} UTC"
    echo "Exit code: ${exit_code:-unknown}"
    echo "AI status: $ai_status"
    if [ -n "$exec_time_ms" ]; then
        local exec_time_s
        exec_time_s=$(echo "$exec_time_ms" | awk '{printf "%.1fs", $1/1000}')
        echo "AI time:   ${exec_time_s}"
    fi
    if [ -n "$tokens_in" ] || [ -n "$tokens_out" ]; then
        echo "Tokens:    in=${tokens_in:-—} • out=${tokens_out:-—}"
    fi
    echo "Dashboard: ${dashboard_url}/sessions/${session_id}"
    if [ -n "$claude_session_id" ]; then
        echo "Resume:    claude --resume ${claude_session_id}"
    fi
    echo ""

    case "$ai_status" in
        done)
            echo "Analysis:"
            echo "---------"
            echo "$result"
            ;;
        pending)
            echo "(Analysis is still running — try again shortly)"
            ;;
        none)
            echo "(No AI analysis for this session — AI may be disabled or images unavailable)"
            ;;
    esac
}

# _mec_ai_last
# Show the most recent session: reads metadata from the log file (source of
# truth) and the analysis result from the sidecar if available.
_mec_ai_last() {
    local log_dir="${MEC_LOG_DIR:-${MEC_HOME}/logs}"

    if [ ! -d "$log_dir" ]; then
        echo "No logs found (directory not created yet)."
        return 0
    fi

    local log_file
    log_file=$(find "$log_dir" -name "*.json" ! -name "*.bak" ! -type d 2>/dev/null | awk -F/ '{print $NF, $0}' | sort -rk1 | awk '{print $2}' | head -1)

    if [ -z "$log_file" ]; then
        echo "No sessions found yet. Run any tool with AI enabled first."
        return 0
    fi

    _mec_ai_print_session "$log_file"
}

# _mec_ai_show <session_id>
# Show a specific session by session ID.
_mec_ai_show() {
    local session_id="$1"
    if [ -z "$session_id" ]; then
        echo "Usage: mec ai show <session_id>" >&2
        return 1
    fi

    local log_file
    log_file=$(log_find_by_session_id "$session_id")

    if [ -z "$log_file" ]; then
        echo "Session not found: $session_id" >&2
        return 1
    fi

    _mec_ai_print_session "$log_file"
}

# _mec_ai_logs [--last N]
# List recent sessions showing tool, timestamp, and AI analysis status.
_mec_ai_logs() {
    local last_n=20

    while [ $# -gt 0 ]; do
        case "$1" in
            --last)
                last_n="$2"
                shift 2
                ;;
            *)
                echo "Unknown option: $1" >&2
                echo "Usage: mec ai logs [--last N]" >&2
                return 1
                ;;
        esac
    done

    local log_dir="${MEC_LOG_DIR:-${MEC_HOME}/logs}"

    if [ ! -d "$log_dir" ]; then
        echo "No log directory found at $log_dir"
        return 0
    fi

    local log_files
    log_files=$(find "$log_dir" -name "*.json" ! -name "*.bak" ! -type d 2>/dev/null | awk -F/ '{print $NF, $0}' | sort -rk1 | awk '{print $2}' | head -n "$last_n")

    if [ -z "$log_files" ]; then
        echo "No log files found."
        return 0
    fi

    printf "%-25s %-12s %-6s %-10s %-8s %s\n" "TIMESTAMP (UTC)" "TOOL" "EXIT" "AI" "AI TIME" "SESSION ID"
    printf "%-25s %-12s %-6s %-10s %-8s %s\n" "-------------------------" "------------" "------" "----------" "--------" "----------"

    echo "$log_files" | while IFS= read -r log_file; do
        [ -f "$log_file" ] || continue

        local session_id tool exit_code start_time ai_status
        session_id=$(grep '"session_id"' "$log_file" 2>/dev/null | sed 's/.*"session_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)
        tool=$(grep '"tool"' "$log_file" 2>/dev/null | sed 's/.*"tool"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)
        exit_code=$(grep '"exit_code"' "$log_file" 2>/dev/null | sed 's/.*"exit_code"[[:space:]]*:[[:space:]]*\(-\{0,1\}[0-9][0-9]*\).*/\1/' | head -1)
        start_time=$(grep '"start_time"' "$log_file" 2>/dev/null | sed 's/.*"start_time"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)

        local ts_display
        ts_display=$(echo "$start_time" | sed 's/T/ /; s/\.[0-9]*//' | cut -c1-19)
        [ -z "$ts_display" ] && ts_display="unknown"
        ts_display="${ts_display} UTC"

        # Derive sidecar path
        local ai_file
        ai_file=$(echo "$log_file" | sed 's|/logs/|/ai-analyses/|')
        if [ -f "$ai_file" ]; then
            local has_result
            has_result=$(grep '"result"' "$ai_file" 2>/dev/null | grep -v '"result"[[:space:]]*:[[:space:]]*""' | head -1)
            if [ -n "$has_result" ]; then
                ai_status="done"
            else
                ai_status="pending"
            fi
        else
            ai_status="none"
        fi

        local ai_time="--"
        if [ "$ai_status" = "done" ] && [ -f "$ai_file" ]; then
            local _exec_ms
            _exec_ms=$(grep '"execution_time_ms"' "$ai_file" 2>/dev/null \
                | sed 's/.*"execution_time_ms"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/' \
                | tail -1)
            if [ -n "$_exec_ms" ]; then
                ai_time=$(echo "$_exec_ms" | awk '{printf "%.1fs", $1/1000}')
            fi
        fi

        printf "%-25s %-12s %-6s %-10s %-8s %s\n" "$ts_display" "${tool:-?}" "${exit_code:-?}" "$ai_status" "$ai_time" "${session_id:-?}"
    done
}

# ----------------------------------------------------------------------------
# Telemetry Commands
# ----------------------------------------------------------------------------

mec_telemetry() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    case "$subcmd" in
        enable)
            config_set "telemetry.enabled" "true"
            echo "Telemetry enabled."
            echo "Session metadata will be written to ${MEC_LOG_DIR:-${MEC_HOME}/logs}/"
            echo "To also capture stdout/stderr: mec logs enable"
            ;;
        disable)
            config_set "telemetry.enabled" "false"
            echo "Telemetry disabled."
            ;;
        status)
            echo "Telemetry Status"
            echo "----------------"
            local tel_enabled log_enabled tel_label log_label
            tel_enabled=$(config_get_default "telemetry.enabled" "true")
            log_enabled=$(config_get_default "logs.enabled" "false")
            [ "$tel_enabled" = "true" ] && tel_label="enabled" || tel_label="disabled"
            [ "$log_enabled" = "true" ] && log_label="enabled" || log_label="disabled"
            echo "  Telemetry:       $tel_label  (session_id, tool, exit_code, timing)"
            echo "  Output capture:  $log_label  (stdout/stderr)"
            ;;
        help|--help|-h)
            local _b="" _r=""
            if [ -t 1 ]; then _b=$(printf '\033[1m'); _r=$(printf '\033[0m'); fi
            printf '%s\n' "${_b}USAGE${_r}"
            printf '%s\n' "  mec telemetry <command>"
            printf '%s\n' ""
            printf '%s\n' "${_b}COMMANDS${_r}"
            printf '%s\n' "  enable   Enable session telemetry (session_id, tool, exit_code, timing)"
            printf '%s\n' "  disable  Disable session telemetry"
            printf '%s\n' "  status   Show telemetry and output capture state"
            printf '%s\n' "  help     Show this help"
            printf '%s\n' ""
            printf '%s\n' "${_b}EXAMPLES${_r}"
            printf '%s\n' "  mec telemetry enable"
            printf '%s\n' "  mec telemetry status"
            ;;
        *)
            echo "Unknown telemetry command: $subcmd" >&2
            echo "Run 'mec telemetry help' for usage information" >&2
            return 1
            ;;
    esac
}

# ----------------------------------------------------------------------------
# Logging Commands
# ----------------------------------------------------------------------------

mec_logs() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    case "$subcmd" in
        status)
            echo "Logging Status"
            echo "--------------"
            local output_enabled output_label
            output_enabled=$(config_get_default "logs.enabled" "false")
            [ "$output_enabled" = "true" ] && output_label="enabled" || output_label="disabled"
            echo "  Output capture:  $output_label  (stdout/stderr)"
            local log_dir="${MEC_LOG_DIR:-${MEC_HOME}/logs}"
            echo "  Log directory:   $log_dir"
            if [ -d "$log_dir" ]; then
                local count
                count=$(find "$log_dir" -name "*.json" 2>/dev/null | wc -l | tr -d ' ')
                echo "  Log files:       $count JSON files"
            else
                echo "  Log files:       none (directory not created yet)"
            fi
            ;;
        enable)
            config_set "logs.enabled" "true"
            echo "Output capture enabled. stdout/stderr will be saved to log files."
            echo "Note: logs may grow large. Use 'mec logs disable' to turn off when needed."
            ;;
        disable)
            config_set "logs.enabled" "false"
            echo "Output capture disabled. Session telemetry is still recorded."
            ;;
        show)
            _mec_logs_show "$@"
            ;;
        list)
            _mec_logs_list "$@"
            ;;
        failures)
            _mec_logs_failures "$@"
            ;;
        stats)
            _mec_logs_stats
            ;;
        help|--help|-h)
            local _b="" _r=""
            if [ -t 1 ]; then _b=$(printf '\033[1m'); _r=$(printf '\033[0m'); fi
            printf '%s\n' "${_b}USAGE${_r}"
            printf '%s\n' "  mec logs <command>"
            printf '%s\n' ""
            printf '%s\n' "${_b}COMMANDS${_r}"
            printf '%s\n' "  status                           Show output capture status and log file count"
            printf '%s\n' "  enable                           Enable stdout/stderr capture in log files"
            printf '%s\n' "  disable                          Disable stdout/stderr capture (telemetry still recorded)"
            printf '%s\n' "  show <session_id>                Show log details for a session"
            printf '%s\n' "  list [--tool <name>] [--last N]  List recent executions (default: last 20)"
            printf '%s\n' "  failures [--last N]              List recent failed executions (default: last 20)"
            printf '%s\n' "  stats                            Show execution statistics"
            printf '%s\n' "  help                             Show this help"
            printf '%s\n' ""
            printf '%s\n' "${_b}EXAMPLES${_r}"
            printf '%s\n' "  mec logs status"
            printf '%s\n' "  mec logs enable"
            printf '%s\n' "  mec logs show mec-node-1234567890"
            printf '%s\n' "  mec logs list"
            printf '%s\n' "  mec logs list --tool node"
            printf '%s\n' "  mec logs list --last 5"
            printf '%s\n' "  mec logs failures --last 10"
            printf '%s\n' "  mec logs stats"
            ;;
        *)
            echo "Unknown logs command: $subcmd" >&2
            echo "Run 'mec logs help' for usage information" >&2
            return 1
            ;;
    esac
}

# _ai_sidecar_exists <log_file>
# Returns 0 if a sidecar AI analysis file exists for the given log file.
_ai_sidecar_exists() {
    local log_file="$1"
    local ai_file
    ai_file=$(echo "$log_file" | sed 's|/logs/|/ai-analyses/|')
    [ -f "$ai_file" ]
}

# _mec_logs_show <session_id>
# Print log details for a specific session
_mec_logs_show() {
    local session_id="$1"
    if [ -z "$session_id" ]; then
        echo "Usage: mec logs show <session_id>" >&2
        return 1
    fi

    local log_file
    log_file=$(log_find_by_session_id "$session_id")

    if [ -z "$log_file" ]; then
        echo "Session not found: $session_id" >&2
        return 1
    fi

    local tool exit_code start_time end_time duration_str image command cwd duration_ms_val
    tool=$(grep '"tool"' "$log_file" 2>/dev/null | sed 's/.*"tool"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)
    image=$(grep '"image"' "$log_file" 2>/dev/null | sed 's/.*"image"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)
    command=$(grep '"command"' "$log_file" 2>/dev/null | sed 's/.*"command"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)
    cwd=$(grep '"cwd"' "$log_file" 2>/dev/null | sed 's/.*"cwd"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)
    exit_code=$(grep '"exit_code"' "$log_file" 2>/dev/null | sed 's/.*"exit_code"[[:space:]]*:[[:space:]]*\(-\{0,1\}[0-9][0-9]*\).*/\1/' | head -1)
    start_time=$(grep '"start_time"' "$log_file" 2>/dev/null | sed 's/.*"start_time"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)
    end_time=$(grep '"end_time"' "$log_file" 2>/dev/null | sed 's/.*"end_time"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)

    duration_str="-"
    duration_ms_val=$(grep '"duration_ms"' "$log_file" 2>/dev/null | sed 's/.*"duration_ms"[[:space:]]*:[[:space:]]*\([0-9]*\).*/\1/' | head -1)
    if [ -n "$duration_ms_val" ] && [ "$duration_ms_val" -ge 0 ] 2>/dev/null; then
        duration_str="${duration_ms_val}ms"
    fi

    local output_captured="yes"
    if grep -q '"stdout": null' "$log_file" 2>/dev/null; then
        output_captured="no  (run 'mec logs enable' to capture)"
    fi

    local ts_display
    ts_display=$(echo "$start_time" | sed 's/T/ /; s/\.[0-9]*//' | cut -c1-19)

    echo "Session:   ${session_id}"
    echo "Timestamp: ${ts_display:-unknown} UTC"
    echo "Tool:      ${tool:-unknown}"
    echo "Image:     ${image:-unknown}"
    echo "Command:   ${command:-unknown}"
    echo "Directory: ${cwd:-unknown}"
    echo "Exit code: ${exit_code:-?}"
    echo "Duration:  ${duration_str}"
    echo "Output:    ${output_captured}"
    echo "Log file:  ${log_file}"
}

# _mec_logs_list [--tool <name>] [--last N]
# List recent execution log entries from $MEC_HOME/logs/
_mec_logs_list() {
    local filter_tool=""
    local last_n=20

    # Parse arguments
    while [ $# -gt 0 ]; do
        case "$1" in
            --tool)
                filter_tool="$2"
                shift 2
                ;;
            --last)
                last_n="$2"
                shift 2
                ;;
            *)
                echo "Unknown option: $1" >&2
                echo "Usage: mec logs list [--tool <name>] [--last N]" >&2
                return 1
                ;;
        esac
    done

    local log_dir="${MEC_LOG_DIR:-${MEC_HOME}/logs}"

    if [ ! -d "$log_dir" ]; then
        echo "No log directory found at $log_dir"
        return 0
    fi

    # Find JSON log files (exclude .bak files)
    local search_dir="$log_dir"
    if [ -n "$filter_tool" ]; then
        search_dir="${log_dir}/${filter_tool}"
        if [ ! -d "$search_dir" ]; then
            echo "No logs found for tool: $filter_tool"
            return 0
        fi
    fi

    local log_files
    log_files=$(find "$search_dir" -name "*.json" ! -name "*.bak" 2>/dev/null | awk -F/ '{print $NF, $0}' | sort -rk1 | awk '{print $2}' | head -n "$last_n")

    if [ -z "$log_files" ]; then
        echo "No log files found."
        return 0
    fi

    # Print table header
    printf "%-21s %-12s %-6s %-10s %-4s %-5s %s\n" "TIMESTAMP" "TOOL" "EXIT" "DURATION" "AI" "LOGS" "SESSION ID"
    printf "%-21s %-12s %-6s %-10s %-4s %-5s %s\n" "---------------------" "------------" "------" "----------" "----" "-----" "----------"

    echo "$log_files" | while IFS= read -r log_file; do
        [ -f "$log_file" ] || continue

        local tool exit_code start_time end_time has_ai has_logs duration_str session_id

        # Extract fields using grep+sed (portable; BSD awk lacks POSIX char classes in -F)
        tool=$(grep '"tool"' "$log_file" 2>/dev/null | sed 's/.*"tool"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)
        exit_code=$(grep '"exit_code"' "$log_file" 2>/dev/null | sed 's/.*"exit_code"[[:space:]]*:[[:space:]]*\(-\{0,1\}[0-9][0-9]*\).*/\1/' | head -1)
        start_time=$(grep '"start_time"' "$log_file" 2>/dev/null | sed 's/.*"start_time"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)
        end_time=$(grep '"end_time"' "$log_file" 2>/dev/null | sed 's/.*"end_time"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)
        session_id=$(grep '"session_id"' "$log_file" 2>/dev/null | sed 's/.*"session_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)

        # Check for AI sidecar
        if _ai_sidecar_exists "$log_file"; then
            has_ai="yes"
        else
            has_ai="no"
        fi

        # Check if output was captured (stdout: null means capture was off)
        if grep -q '"stdout": null' "$log_file" 2>/dev/null; then
            has_logs="no"
        else
            has_logs="yes"
        fi

        # Format timestamp (strip T and fractional seconds)
        local ts_display
        ts_display=$(echo "$start_time" | sed 's/T/ /; s/\.[0-9]*//' | cut -c1-19)
        [ -z "$ts_display" ] && ts_display="unknown"

        # Compute duration — prefer duration_ms field, fall back to timestamp diff
        duration_str="-"
        local duration_ms_val
        duration_ms_val=$(grep '"duration_ms"' "$log_file" 2>/dev/null | sed 's/.*"duration_ms"[[:space:]]*:[[:space:]]*\([0-9]*\).*/\1/' | head -1)
        if [ -n "$duration_ms_val" ] && [ "$duration_ms_val" -ge 0 ] 2>/dev/null; then
            duration_str="$(( duration_ms_val / 1000 ))s"
        elif [ -n "$start_time" ] && [ -n "$end_time" ]; then
            # Fall back to python timestamp diff for pre-existing log files
            if command -v python3 >/dev/null 2>&1; then
                duration_str=$(python3 -c "
import sys
from datetime import datetime
try:
    fmt = '%Y-%m-%dT%H:%M:%S'
    s = '$start_time'.split('.')[0].rstrip('Z')
    e = '$end_time'.split('.')[0].rstrip('Z')
    delta = datetime.strptime(e, fmt) - datetime.strptime(s, fmt)
    secs = int(delta.total_seconds())
    print(str(secs) + 's')
except:
    print('-')
" 2>/dev/null || echo "-")
            fi
        fi

        [ -z "$tool" ] && tool="unknown"
        [ -z "$exit_code" ] && exit_code="?"

        printf "%-21s %-12s %-6s %-10s %-4s %-5s %s\n" "$ts_display" "$tool" "$exit_code" "$duration_str" "$has_ai" "$has_logs" "${session_id:-?}"
    done
}

# _mec_logs_failures [--last N]
# List recent failed executions (exit_code != 0)
_mec_logs_failures() {
    local last_n=20

    while [ $# -gt 0 ]; do
        case "$1" in
            --last)
                last_n="$2"
                shift 2
                ;;
            *)
                echo "Unknown option: $1" >&2
                echo "Usage: mec logs failures [--last N]" >&2
                return 1
                ;;
        esac
    done

    local log_dir="${MEC_LOG_DIR:-${MEC_HOME}/logs}"

    if [ ! -d "$log_dir" ]; then
        echo "No log directory found at $log_dir"
        return 0
    fi

    local all_files
    all_files=$(find "$log_dir" -name "*.json" ! -name "*.bak" 2>/dev/null | sort -r)

    if [ -z "$all_files" ]; then
        echo "No log files found."
        return 0
    fi

    # Print table header
    printf "%-21s %-12s %-6s %-10s %-4s %-5s %s\n" "TIMESTAMP" "TOOL" "EXIT" "DURATION" "AI" "LOGS" "SESSION ID"
    printf "%-21s %-12s %-6s %-10s %-4s %-5s %s\n" "---------------------" "------------" "------" "----------" "----" "-----" "----------"

    local shown=0
    echo "$all_files" | while IFS= read -r log_file; do
        [ -f "$log_file" ] || continue
        [ "$shown" -ge "$last_n" ] && break

        local tool exit_code start_time end_time has_ai has_logs duration_str session_id

        tool=$(grep '"tool"' "$log_file" 2>/dev/null | sed 's/.*"tool"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)
        exit_code=$(grep '"exit_code"' "$log_file" 2>/dev/null | sed 's/.*"exit_code"[[:space:]]*:[[:space:]]*\(-\{0,1\}[0-9][0-9]*\).*/\1/' | head -1)

        # Only show non-zero exit codes
        [ -z "$exit_code" ] && continue
        [ "$exit_code" = "0" ] && continue

        start_time=$(grep '"start_time"' "$log_file" 2>/dev/null | sed 's/.*"start_time"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)
        end_time=$(grep '"end_time"' "$log_file" 2>/dev/null | sed 's/.*"end_time"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)
        session_id=$(grep '"session_id"' "$log_file" 2>/dev/null | sed 's/.*"session_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)

        if _ai_sidecar_exists "$log_file"; then
            has_ai="yes"
        else
            has_ai="no"
        fi

        if grep -q '"stdout": null' "$log_file" 2>/dev/null; then
            has_logs="no"
        else
            has_logs="yes"
        fi

        local ts_display
        ts_display=$(echo "$start_time" | sed 's/T/ /; s/\.[0-9]*//' | cut -c1-19)
        [ -z "$ts_display" ] && ts_display="unknown"

        duration_str="-"
        if [ -n "$start_time" ] && [ -n "$end_time" ]; then
            if command -v python3 >/dev/null 2>&1; then
                duration_str=$(python3 -c "
import sys
from datetime import datetime
try:
    fmt = '%Y-%m-%dT%H:%M:%S'
    s = '$start_time'.split('.')[0].rstrip('Z')
    e = '$end_time'.split('.')[0].rstrip('Z')
    delta = datetime.strptime(e, fmt) - datetime.strptime(s, fmt)
    secs = int(delta.total_seconds())
    print(str(secs) + 's')
except:
    print('-')
" 2>/dev/null || echo "-")
            fi
        fi

        [ -z "$tool" ] && tool="unknown"

        printf "%-21s %-12s %-6s %-10s %-4s %-5s %s\n" "$ts_display" "$tool" "$exit_code" "$duration_str" "$has_ai" "$has_logs" "${session_id:-?}"
        shown=$((shown + 1))
    done
}

# _mec_logs_stats
# Show aggregate execution statistics
_mec_logs_stats() {
    local log_dir="${MEC_LOG_DIR:-${MEC_HOME}/logs}"

    if [ ! -d "$log_dir" ]; then
        echo "No log directory found at $log_dir"
        return 0
    fi

    local all_files
    all_files=$(find "$log_dir" -name "*.json" ! -name "*.bak" 2>/dev/null)

    if [ -z "$all_files" ]; then
        echo "No log files found."
        return 0
    fi

    if command -v python3 >/dev/null 2>&1; then
        python3 - "$log_dir" <<'PYEOF'
import sys, os, json, glob
from datetime import datetime

log_dir = sys.argv[1]
files = glob.glob(os.path.join(log_dir, "**", "*.json"), recursive=True)
files = [f for f in files if not f.endswith(".bak")]

total = 0
failures = 0
ai_count = 0
tool_stats = {}  # tool -> {runs, failures, total_secs}

for f in files:
    try:
        with open(f) as fh:
            data = json.load(fh)
    except Exception:
        continue

    total += 1
    tool = data.get("tool", "unknown")
    exec_data = data.get("execution", {})
    exit_code = exec_data.get("exit_code", 0)
    start_time = exec_data.get("start_time", "")
    end_time = exec_data.get("end_time", "")

    ai_sidecar = f.replace('/logs/', '/ai-analyses/')
    if os.path.exists(ai_sidecar):
        ai_count += 1

    if exit_code != 0:
        failures += 1

    duration_secs = None
    if start_time and end_time:
        try:
            fmt = "%Y-%m-%dT%H:%M:%S"
            s = start_time.split(".")[0].rstrip("Z")
            e = end_time.split(".")[0].rstrip("Z")
            delta = datetime.strptime(e, fmt) - datetime.strptime(s, fmt)
            duration_secs = delta.total_seconds()
        except Exception:
            pass

    if tool not in tool_stats:
        tool_stats[tool] = {"runs": 0, "failures": 0, "total_secs": 0, "timed": 0}
    tool_stats[tool]["runs"] += 1
    if exit_code != 0:
        tool_stats[tool]["failures"] += 1
    if duration_secs is not None:
        tool_stats[tool]["total_secs"] += duration_secs
        tool_stats[tool]["timed"] += 1

success_rate = int((total - failures) / total * 100) if total > 0 else 0

print("Execution Stats")
print("---------------")
print(f"  Total runs:     {total}")
print(f"  Failures:       {failures}  ({100 - success_rate}%)")
print()
print(f"  {'Tool':<14} {'Runs':>5}  {'Failures':>8}  {'Avg Duration':>12}")
print(f"  {'-'*14} {'-'*5}  {'-'*8}  {'-'*12}")
for tool, stats in sorted(tool_stats.items(), key=lambda x: -x[1]["runs"]):
    avg_dur = "-"
    if stats["timed"] > 0:
        avg_dur = str(int(stats["total_secs"] / stats["timed"])) + "s"
    print(f"  {tool:<14} {stats['runs']:>5}  {stats['failures']:>8}  {avg_dur:>12}")
print()
print(f"  AI analyses:   {ai_count} saved")
PYEOF
    else
        # Fallback: basic counts without python3
        local total failures ai_count
        total=$(echo "$all_files" | wc -l | tr -d ' ')
        failures=$(echo "$all_files" | while IFS= read -r f; do
            [ -f "$f" ] || continue
            ec=$(awk -F'"exit_code"[[:space:]]*:[[:space:]]*' '{print $2}' "$f" 2>/dev/null | awk -F'[^0-9-]' '{print $1; exit}')
            [ -n "$ec" ] && [ "$ec" != "0" ] && echo "1"
        done | wc -l | tr -d ' ')
        ai_count=$(echo "$all_files" | while IFS= read -r f; do
            [ -f "$f" ] || continue
            ai_f=$(echo "$f" | sed 's|/logs/|/ai-analyses/|')
            [ -f "$ai_f" ] && echo "1"
        done | wc -l | tr -d ' ')

        echo "Execution Stats"
        echo "---------------"
        echo "  Total runs:   $total"
        echo "  Failures:     $failures"
        echo "  AI analyses:  $ai_count saved"
        echo ""
        echo "  (Install python3 for per-tool breakdown)"
    fi
}

# ----------------------------------------------------------------------------
# Claude Firewall Commands
# ----------------------------------------------------------------------------

mec_claude_firewall() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    local GITHUB_META_KEY="ai.claude.firewall.github_meta_endpoints"
    local DNS_DOMAINS_KEY="ai.claude.firewall.dns_resolve_domains"

    case "$subcmd" in
        status)
            echo "Claude Firewall Status"
            echo "----------------------"
            local enabled
            enabled=$(config_get_default "ai.claude.firewall.enabled" "false")
            echo "  Enabled: $enabled"
            echo ""
            echo "  GitHub meta endpoints:"
            config_get_list_default "$GITHUB_META_KEY" | while IFS= read -r item; do
                echo "    - $item"
            done
            echo ""
            echo "  DNS resolve domains:"
            config_get_list_default "$DNS_DOMAINS_KEY" | while IFS= read -r item; do
                echo "    - $item"
            done
            ;;
        list)
            echo "GitHub meta endpoints:"
            config_get_list_default "$GITHUB_META_KEY" | while IFS= read -r item; do
                echo "  - $item"
            done
            echo ""
            echo "DNS resolve domains:"
            config_get_list_default "$DNS_DOMAINS_KEY" | while IFS= read -r item; do
                echo "  - $item"
            done
            ;;
        add)
            local list_type="${1:-}"
            local domain="${2:-}"
            if [ -z "$list_type" ] || [ -z "$domain" ]; then
                echo "Usage: mec claude firewall add <github-meta|dns> <domain>" >&2
                return 1
            fi
            case "$list_type" in
                github-meta)
                    _firewall_add_domain "$GITHUB_META_KEY" "$domain"
                    echo "Added '$domain' to github-meta endpoints."
                    echo "Run 'mec claude firewall rebuild' to apply changes."
                    ;;
                dns)
                    _firewall_add_domain "$DNS_DOMAINS_KEY" "$domain"
                    echo "Added '$domain' to DNS resolve domains."
                    echo "Run 'mec claude firewall rebuild' to apply changes."
                    ;;
                *)
                    echo "Unknown list type: $list_type" >&2
                    echo "Use 'github-meta' or 'dns'" >&2
                    return 1
                    ;;
            esac
            ;;
        remove)
            local list_type="${1:-}"
            local domain="${2:-}"
            if [ -z "$list_type" ] || [ -z "$domain" ]; then
                echo "Usage: mec claude firewall remove <github-meta|dns> <domain>" >&2
                return 1
            fi
            case "$list_type" in
                github-meta)
                    _firewall_remove_domain "$GITHUB_META_KEY" "$domain"
                    echo "Removed '$domain' from github-meta endpoints."
                    echo "Run 'mec claude firewall rebuild' to apply changes."
                    ;;
                dns)
                    _firewall_remove_domain "$DNS_DOMAINS_KEY" "$domain"
                    echo "Removed '$domain' from DNS resolve domains."
                    echo "Run 'mec claude firewall rebuild' to apply changes."
                    ;;
                *)
                    echo "Unknown list type: $list_type" >&2
                    echo "Use 'github-meta' or 'dns'" >&2
                    return 1
                    ;;
            esac
            ;;
        enable)
            config_set "ai.claude.firewall.enabled" "true"
            echo "Claude firewall enabled."
            echo "Run 'mec claude firewall rebuild' to build the image with resolved IPs."
            ;;
        disable)
            config_set "ai.claude.firewall.enabled" "false"
            echo "Claude firewall disabled."
            ;;
        rebuild)
            echo "Rebuilding Claude Code Docker image with updated domain resolution..."
            local build_script="${BASE_DIR}/docker/claude/build"
            if [ ! -f "$build_script" ]; then
                echo "ERROR: Build script not found: $build_script" >&2
                return 1
            fi
            bash "$build_script"
            echo "Rebuild complete. IPs are now baked into the image."
            ;;
        help|--help|-h)
            local _b="" _r=""
            if [ -t 1 ]; then _b=$(printf '\033[1m'); _r=$(printf '\033[0m'); fi
            printf '%s\n' "${_b}USAGE${_r}"
            printf '%s\n' "  mec claude firewall <command> [arguments]"
            printf '%s\n' ""
            printf '%s\n' "${_b}COMMANDS${_r}"
            printf '%s\n' "  status                              Show firewall enabled state and domain lists"
            printf '%s\n' "  list                                List all configured domains"
            printf '%s\n' "  add <github-meta|dns> <domain>      Add a domain to the firewall allow list"
            printf '%s\n' "  remove <github-meta|dns> <domain>   Remove a domain from the allow list"
            printf '%s\n' "  enable                              Enable the container firewall"
            printf '%s\n' "  disable                             Disable the container firewall"
            printf '%s\n' "  rebuild                             Rebuild Docker image with fresh IP resolution"
            printf '%s\n' "  help                                Show this help"
            printf '%s\n' ""
            printf '%s\n' "${_b}DOMAIN LIST TYPES${_r}"
            printf '%s\n' "  github-meta   GitHub API endpoints (IPs fetched via api.github.com/meta CIDR ranges)"
            printf '%s\n' "  dns           Domains resolved via DNS at Docker build time"
            printf '%s\n' ""
            printf '%s\n' "${_b}NOTES${_r}"
            printf '%s\n' "  - IPs are resolved at 'docker build' time and baked into the image"
            printf '%s\n' "  - Run 'mec claude firewall rebuild' after any domain changes"
            printf '%s\n' "  - Firewall requires NET_ADMIN capability (added automatically when enabled)"
            printf '%s\n' ""
            printf '%s\n' "${_b}EXAMPLES${_r}"
            printf '%s\n' "  mec claude firewall status"
            printf '%s\n' "  mec claude firewall list"
            printf '%s\n' "  mec claude firewall add dns custom.example.com"
            printf '%s\n' "  mec claude firewall remove dns custom.example.com"
            printf '%s\n' "  mec claude firewall enable"
            printf '%s\n' "  mec claude firewall rebuild"
            ;;
        *)
            echo "Unknown firewall command: $subcmd" >&2
            echo "Run 'mec claude firewall help' for usage information" >&2
            return 1
            ;;
    esac
}

# ----------------------------------------------------------------------------
# Setup / Install / Uninstall Commands
# ----------------------------------------------------------------------------

mec_setup() {
    local subcmd="${1:-}"
    shift 2>/dev/null || true

    case "$subcmd" in
        "")
            exec "${BASE_DIR}/setup.sh"
            ;;
        status|show)
            exec "${BASE_DIR}/setup.sh" status
            ;;
        help|--help|-h)
            cat <<'EOF'
Usage: mec setup [subcommand]

Subcommands:
  (none)    Open interactive setup TUI
  status    Show installation status
  help      Show this help message

Examples:
  mec setup
  mec setup status
EOF
            ;;
        *)
            echo "Unknown setup subcommand: $subcmd" >&2
            echo "Run 'mec setup help' for usage information" >&2
            return 1
            ;;
    esac
}

mec_install() {
    if [ $# -eq 0 ]; then
        msg_err "Usage: mec install <tool> [tool2 ...]"
        return 1
    fi
    exec "${BASE_DIR}/setup.sh" install "$@"
}

mec_uninstall() {
    if [ $# -eq 0 ]; then
        msg_err "Usage: mec uninstall <tool> [tool2 ...]"
        return 1
    fi
    exec "${BASE_DIR}/setup.sh" uninstall "$@"
}

# ----------------------------------------------------------------------------
# Dashboard Commands
# ----------------------------------------------------------------------------

MEC_DASHBOARD_CONTAINER="mec-dashboard"

mec_dashboard() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    local dashboard_url
    dashboard_url=$(_mec_dashboard_url)
    local dashboard_port
    dashboard_port=$(config_get_default "ai.dashboard.port" "4242" 2>/dev/null || echo "4242")

    case "$subcmd" in
        start)
            if docker inspect "$MEC_DASHBOARD_CONTAINER" >/dev/null 2>&1; then
                local state
                state=$(docker inspect --format '{{.State.Status}}' "$MEC_DASHBOARD_CONTAINER" 2>/dev/null)
                if [ "$state" = "running" ]; then
                    echo "Dashboard is already running at ${dashboard_url}"
                    return 0
                fi
                # Container exists but stopped — remove it first
                docker rm "$MEC_DASHBOARD_CONTAINER" >/dev/null 2>&1 || true
            fi

            if ! docker image inspect "$MEC_IMAGE_DASHBOARD" >/dev/null 2>&1; then
                echo "[mec] ERROR: Dashboard image not found: $MEC_IMAGE_DASHBOARD" >&2
                echo "  Pull it with: docker pull $MEC_IMAGE_DASHBOARD" >&2
                return 1
            fi

            docker run -d \
                --name "$MEC_DASHBOARD_CONTAINER" \
                --restart unless-stopped \
                -p "${dashboard_port}:4242" \
                --volume "${MEC_HOME}:/data:ro" \
                "$MEC_IMAGE_DASHBOARD" >/dev/null

            echo "Dashboard started"
            echo "  UI  →  ${dashboard_url}"
            echo "  API →  ${dashboard_url}/api"
            ;;
        stop)
            if ! docker inspect "$MEC_DASHBOARD_CONTAINER" >/dev/null 2>&1; then
                echo "Dashboard is not running."
                return 0
            fi
            docker stop "$MEC_DASHBOARD_CONTAINER" >/dev/null
            docker rm "$MEC_DASHBOARD_CONTAINER" >/dev/null
            echo "Dashboard stopped."
            ;;
        status)
            if ! docker inspect "$MEC_DASHBOARD_CONTAINER" >/dev/null 2>&1; then
                echo "Dashboard: not running"
                return 0
            fi
            local state
            state=$(docker inspect --format '{{.State.Status}}' "$MEC_DASHBOARD_CONTAINER" 2>/dev/null)
            echo "Dashboard: $state"
            if [ "$state" = "running" ]; then
                echo "  UI  →  ${dashboard_url}"
                echo "  API →  ${dashboard_url}/api"
            fi
            ;;
        open)
            if command -v open >/dev/null 2>&1; then
                open "${dashboard_url}"
            elif command -v xdg-open >/dev/null 2>&1; then
                xdg-open "${dashboard_url}"
            else
                echo "${dashboard_url}"
            fi
            ;;
        help|--help|-h)
            local _b="" _r=""
            if [ -t 1 ]; then _b=$(printf '\033[1m'); _r=$(printf '\033[0m'); fi
            printf '%s\n' "${_b}USAGE${_r}"
            printf '%s\n' "  mec dashboard <command>"
            printf '%s\n' ""
            printf '%s\n' "${_b}COMMANDS${_r}"
            printf '%s\n' "  start     Start the dashboard (API + UI served from the same container)"
            printf '%s\n' "  stop      Stop and remove the dashboard container"
            printf '%s\n' "  restart   Stop then start (use --rebuild to also rebuild the image first)"
            printf '%s\n' "  rebuild   Build the dashboard Docker image locally"
            printf '%s\n' "  status    Show dashboard container status"
            printf '%s\n' "  open      Open the dashboard in the default browser"
            printf '%s\n' "  help      Show this help"
            printf '%s\n' ""
            printf '%s\n' "${_b}CONFIGURATION${_r}"
            printf '%s\n' "  ai.dashboard.port  Port for the dashboard (default: 4242)"
            printf '%s\n' "  Set with: mec config set ai.dashboard.port <port>"
            printf '%s\n' ""
            printf '%s\n' "${_b}EXAMPLES${_r}"
            printf '%s\n' "  mec dashboard start"
            printf '%s\n' "  mec dashboard status"
            printf '%s\n' "  mec dashboard restart"
            printf '%s\n' "  mec dashboard restart --rebuild"
            printf '%s\n' "  mec dashboard rebuild"
            printf '%s\n' "  mec dashboard open"
            printf '%s\n' "  mec dashboard stop"
            ;;
        rebuild)
            local _dockerfile
            _dockerfile="${BASE_DIR}/docker/dashboard/Dockerfile"
            local _build_context
            _build_context="${BASE_DIR}/services/dashboard"
            if [ ! -f "$_dockerfile" ]; then
                echo "[mec] ERROR: Dockerfile not found at $_dockerfile" >&2
                return 1
            fi
            if [ ! -d "$_build_context" ]; then
                echo "[mec] ERROR: Build context not found at $_build_context" >&2
                return 1
            fi
            echo "Building $MEC_IMAGE_DASHBOARD ..."
            docker build -t "$MEC_IMAGE_DASHBOARD" --file "$_dockerfile" "$_build_context"
            echo "Build complete. Run 'mec dashboard restart' to use the new image."
            ;;
        restart)
            local _do_rebuild=0
            for _arg in "$@"; do [ "$_arg" = "--rebuild" ] && _do_rebuild=1; done
            mec_dashboard "stop"
            [ "$_do_rebuild" -eq 1 ] && mec_dashboard "rebuild"
            mec_dashboard "start"
            ;;
        *)
            echo "Unknown dashboard command: $subcmd" >&2
            echo "Run 'mec dashboard help' for usage" >&2
            return 1
            ;;
    esac
}

# ----------------------------------------------------------------------------
# Doctor Commands
# ----------------------------------------------------------------------------

mec_doctor() {
    local subcmd="${1:-}"
    shift 2>/dev/null || true

    case "$subcmd" in
        help|--help|-h)
            local _b="" _r=""
            if [ -t 1 ]; then _b=$(printf '\033[1m'); _r=$(printf '\033[0m'); fi
            printf '%s\n' "${_b}USAGE${_r}"
            printf '%s\n' "  mec doctor"
            printf '%s\n' ""
            printf '%s\n' "Run health checks on Docker, Zsh, tools, AI integration, dashboard, and data directory."
            printf '%s\n' "Prints a structured report with ✓ pass / ⚠ warn / ✗ fail per check."
            printf '%s\n' "Exits 1 if any check fails — scriptable."
            printf '%s\n' ""
            printf '%s\n' "${_b}EXAMPLES${_r}"
            printf '%s\n' "  mec doctor"
            printf '%s\n' "  mec doctor && echo \"all good\""
            return 0
            ;;
        ""|run)
            _mec_doctor_run
            return $?
            ;;
        *)
            echo "Unknown doctor command: $subcmd" >&2
            echo "Run 'mec doctor help' for usage" >&2
            return 1
            ;;
    esac
}

_mec_doctor_run() {
    local failures=0
    local warnings=0

    _doc_pass() { echo "  ✓  $*"; }
    _doc_warn() { echo "  ⚠  $*"; warnings=$((warnings + 1)); }
    _doc_fail() { echo "  ✗  $*"; failures=$((failures + 1)); }

    # ------------------------------------------------------------------
    # 1. Docker
    # ------------------------------------------------------------------
    if ! command -v docker >/dev/null 2>&1; then
        _doc_fail "Docker: not installed or not in PATH"
    elif ! docker info >/dev/null 2>&1; then
        _doc_fail "Docker daemon: not running  (start Docker Desktop or dockerd)"
    else
        local docker_version
        docker_version=$(docker --version 2>/dev/null | sed 's/Docker version //' | cut -d',' -f1)
        _doc_pass "Docker daemon running  (${docker_version})"
    fi

    # ------------------------------------------------------------------
    # 2. Zsh
    # ------------------------------------------------------------------
    if ! command -v zsh >/dev/null 2>&1; then
        _doc_fail "Zsh: not installed  (required — install via Homebrew: brew install zsh)"
    else
        local zsh_version
        zsh_version=$(zsh --version 2>/dev/null | awk '{print $2}')
        _doc_pass "Zsh: installed  (${zsh_version})"
    fi

    # Oh My Zsh
    if [ -d "${HOME}/.oh-my-zsh" ]; then
        _doc_pass "Oh My Zsh: installed  (~/.oh-my-zsh)"
    else
        _doc_warn "Oh My Zsh: not found  (recommended — https://ohmyz.sh)"
    fi

    # ------------------------------------------------------------------
    # 3. Data directory
    # ------------------------------------------------------------------
    local data_dir="${MEC_DATA_DIR:-${MEC_HOME}}"
    if [ ! -d "$data_dir" ]; then
        _doc_fail "Data directory: not found  (${data_dir} — run 'mec logs enable' to create)"
    elif [ ! -w "$data_dir" ]; then
        _doc_fail "Data directory: not writable  (${data_dir})"
    else
        _doc_pass "Data directory: ${data_dir}  (exists, writable)"
    fi

    # ------------------------------------------------------------------
    # 4. Config file
    # ------------------------------------------------------------------
    local config_file="${CONFIG_FILE:-${MEC_HOME}/config.yaml}"
    if [ -f "$config_file" ]; then
        _doc_pass "Config file: ${config_file}  (exists)"
    else
        _doc_warn "Config file: not found  (defaults will be used — run 'mec config reset' to create)"
    fi

    # ------------------------------------------------------------------
    # 5. Logging
    # ------------------------------------------------------------------
    local logs_enabled output_enabled
    logs_enabled=$(config_get_default "telemetry.enabled" "true")
    output_enabled=$(config_get_default "logs.enabled" "false")
    if [ "$logs_enabled" = "true" ]; then
        if [ "$output_enabled" = "true" ]; then
            _doc_pass "Telemetry: enabled + output capture enabled"
        else
            _doc_pass "Telemetry: enabled  (output capture off — run 'mec logs enable' to capture stdout/stderr)"
        fi
    else
        _doc_warn "Telemetry: disabled  (run 'mec telemetry enable' to enable telemetry)"
    fi

    # ------------------------------------------------------------------
    # 6. AI — enabled state (informational, no failure)
    # ------------------------------------------------------------------
    local ai_enabled
    ai_enabled=$(config_get_default "ai.enabled" "false")
    if [ "$ai_enabled" = "true" ]; then
        _doc_pass "AI: enabled"
    else
        _doc_warn "AI: disabled  (run 'mec ai enable' to activate)"
    fi

    # ------------------------------------------------------------------
    # 7. AI — middleware image
    # ------------------------------------------------------------------
    if docker image inspect "$MEC_IMAGE_AI_SERVICE" >/dev/null 2>&1; then
        _doc_pass "AI middleware image: available  (${MEC_IMAGE_AI_SERVICE})"
    else
        _doc_fail "AI middleware image: not found  (docker pull ${MEC_IMAGE_AI_SERVICE})"
    fi

    # ------------------------------------------------------------------
    # 8. AI — Claude Code image
    # ------------------------------------------------------------------
    if docker image inspect "$MEC_IMAGE_CLAUDE" >/dev/null 2>&1; then
        _doc_pass "Claude Code image: available  (${MEC_IMAGE_CLAUDE})"
    else
        _doc_fail "Claude Code image: not found  (docker pull ${MEC_IMAGE_CLAUDE})"
    fi

    # ------------------------------------------------------------------
    # 9. AI — auth
    # ------------------------------------------------------------------
    if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
        _doc_pass "AI auth: ANTHROPIC_API_KEY set"
    elif [ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
        _doc_pass "AI auth: CLAUDE_CODE_OAUTH_TOKEN set"
    elif [ -f "${HOME}/.claude/.credentials.json" ]; then
        _doc_warn "AI auth: ~/.claude/ found  (interactive use only — set ANTHROPIC_API_KEY for automated analysis)"
    else
        _doc_warn "AI auth: not configured  (set ANTHROPIC_API_KEY or CLAUDE_CODE_OAUTH_TOKEN)"
    fi

    # ------------------------------------------------------------------
    # 10. Dashboard image
    # ------------------------------------------------------------------
    if docker image inspect "$MEC_IMAGE_DASHBOARD" >/dev/null 2>&1; then
        _doc_pass "Dashboard image: available  (${MEC_IMAGE_DASHBOARD})"
    else
        _doc_warn "Dashboard image: not found  (docker pull ${MEC_IMAGE_DASHBOARD})"
    fi

    # ------------------------------------------------------------------
    # 11. Dashboard running
    # ------------------------------------------------------------------
    local dashboard_url
    dashboard_url=$(_mec_dashboard_url)
    if docker inspect "$MEC_DASHBOARD_CONTAINER" >/dev/null 2>&1; then
        local dash_state
        dash_state=$(docker inspect --format '{{.State.Status}}' "$MEC_DASHBOARD_CONTAINER" 2>/dev/null)
        if [ "$dash_state" = "running" ]; then
            _doc_pass "Dashboard: running  (${dashboard_url})"
        else
            _doc_warn "Dashboard: ${dash_state}  (run 'mec dashboard start')"
        fi
    else
        _doc_warn "Dashboard: not running  (run 'mec dashboard start')"
    fi

    # ------------------------------------------------------------------
    # Summary
    # ------------------------------------------------------------------
    echo ""
    if [ "$failures" -gt 0 ] && [ "$warnings" -gt 0 ]; then
        echo "doctor: ${failures} failure(s), ${warnings} warning(s)"
    elif [ "$failures" -gt 0 ]; then
        echo "doctor: ${failures} failure(s)"
    elif [ "$warnings" -gt 0 ]; then
        echo "doctor: ${warnings} warning(s)  (no failures)"
    else
        echo "doctor: all checks passed"
    fi

    [ "$failures" -eq 0 ]
}

# ----------------------------------------------------------------------------
# Purge Commands
# ----------------------------------------------------------------------------

mec_purge() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    local opt_tool="" opt_older_than="" opt_only_logs=0 opt_only_ai=0 opt_dry_run=0 opt_yes=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --tool)             opt_tool="$2";        shift 2 ;;
            --older-than)       opt_older_than="$2";  shift 2 ;;
            --only-logs)        opt_only_logs=1;      shift ;;
            --only-ai-analyses) opt_only_ai=1;        shift ;;
            --dry-run)          opt_dry_run=1;        shift ;;
            -y|--yes)           opt_yes=1;            shift ;;
            *)
                echo "Unknown flag: $1" >&2
                echo "Run 'mec purge help' for usage" >&2
                return 1
                ;;
        esac
    done

    # Validate --older-than is a positive integer
    if [ -n "$opt_older_than" ] && ! printf '%s' "$opt_older_than" | grep -qE '^[0-9]+$'; then
        echo "Error: --older-than requires a positive integer (days), got: $opt_older_than" >&2
        return 1
    fi

    # Validate --tool has no path separators
    if [ -n "$opt_tool" ]; then
        case "$opt_tool" in
            */* | *..*) echo "Error: --tool must not contain path separators or '..'" >&2; return 1 ;;
        esac
    fi

    case "$subcmd" in
        data)
            local _data_dir="${MEC_DATA_DIR:-${MEC_HOME}}"
            local log_dir="${MEC_LOG_DIR:-${_data_dir}/logs}"
            local ai_dir="${_data_dir}/ai-analyses"

            local purge_logs=1 purge_ai=1
            [ "$opt_only_ai"   -eq 1 ] && purge_logs=0
            [ "$opt_only_logs" -eq 1 ] && purge_ai=0

            local _label _rest _dir _enabled _find_args _count _answer
            for _entry in "logs:${log_dir}:${purge_logs}" "ai-analyses:${ai_dir}:${purge_ai}"; do
                _label="${_entry%%:*}"
                _rest="${_entry#*:}"
                _dir="${_rest%%:*}"
                _enabled="${_rest##*:}"
                [ "$_enabled" -eq 0 ] && continue
                [ ! -d "$_dir" ] && continue

                _find_args=()
                if [ -n "$opt_tool" ]; then
                    _find_args+=(-path "*/${opt_tool}/*.json")
                else
                    _find_args+=(-name "*.json")
                fi
                _find_args+=(! -name "*.bak")
                [ -n "$opt_older_than" ] && _find_args+=(-mtime "+${opt_older_than}")

                # Count matching files safely
                _count=$(find "$_dir" "${_find_args[@]}" 2>/dev/null | wc -l | tr -d ' ')

                if [ "$_count" -eq 0 ]; then
                    echo "No files to purge in $_label."
                    continue
                fi

                if [ "$opt_dry_run" -eq 1 ]; then
                    echo "[dry-run] Would delete $_count file(s) from $_dir"
                    find "$_dir" "${_find_args[@]}" 2>/dev/null | head -5
                    [ "$_count" -gt 5 ] && echo "  ... and $(( _count - 5 )) more"
                    continue
                fi

                if [ "$opt_yes" -eq 0 ]; then
                    printf "Delete %s file(s) from %s? [y/N] " "$_count" "$_dir"
                    read -r _answer
                    case "$_answer" in
                        y|Y) ;;
                        *) echo "Skipped $_label."; continue ;;
                    esac
                fi

                find "$_dir" "${_find_args[@]}" -print0 2>/dev/null | xargs -0 rm -f
                echo "Deleted $_count file(s) from $_dir"
            done
            ;;
        help|--help|-h|"")
            local _b="" _r=""
            if [ -t 1 ]; then _b=$(printf '\033[1m'); _r=$(printf '\033[0m'); fi
            printf '%s\n' "${_b}USAGE${_r}"
            printf '%s\n' "  mec purge <command> [flags]"
            printf '%s\n' ""
            printf '%s\n' "${_b}COMMANDS${_r}"
            printf '%s\n' "  data      Delete log and AI analysis files (interactive by default)"
            printf '%s\n' "  help      Show this help"
            printf '%s\n' ""
            printf '%s\n' "${_b}FLAGS${_r}"
            printf '%s\n' "  --tool <name>        Only purge files for a specific tool (e.g. node, aws)"
            printf '%s\n' "  --older-than <days>  Only purge files older than N days"
            printf '%s\n' "  --only-logs          Only purge \$MEC_HOME/logs/"
            printf '%s\n' "  --only-ai-analyses   Only purge \$MEC_HOME/ai-analyses/"
            printf '%s\n' "  --dry-run            Preview what would be deleted without deleting"
            printf '%s\n' "  -y, --yes            Skip confirmation prompts"
            printf '%s\n' ""
            printf '%s\n' "${_b}EXAMPLES${_r}"
            printf '%s\n' "  mec purge data                           # purge all logs + AI analyses (interactive)"
            printf '%s\n' "  mec purge data --dry-run                 # preview only"
            printf '%s\n' "  mec purge data --tool node               # only node logs + analyses"
            printf '%s\n' "  mec purge data --older-than 30           # only files older than 30 days"
            printf '%s\n' "  mec purge data --only-logs --tool aws    # only aws logs (keep AI analyses)"
            printf '%s\n' "  mec purge data -y                        # skip confirmation"
            ;;
        *)
            echo "Unknown purge command: $subcmd" >&2
            echo "Run 'mec purge help' for usage" >&2
            return 1
            ;;
    esac
}

# ----------------------------------------------------------------------------
# List Command
# ----------------------------------------------------------------------------

mec_list() {
    local _public_tools="aws:MEC_IMAGE_AWS terraform:MEC_IMAGE_TERRAFORM gcloud:MEC_IMAGE_GCLOUD python:MEC_IMAGE_PYTHON node:MEC_IMAGE_NODE promptfoo:MEC_IMAGE_PROMPTFOO"
    local _custom_tools="claude:MEC_IMAGE_CLAUDE dashboard:MEC_IMAGE_DASHBOARD playwright:MEC_IMAGE_PLAYWRIGHT aws-sso-cred:MEC_IMAGE_AWS_SSO_CRED serverless:MEC_IMAGE_SERVERLESS speedtest:MEC_IMAGE_SPEEDTEST yarn-berry:MEC_IMAGE_YARN_BERRY yarn-plus:MEC_IMAGE_YARN_PLUS ai-service:MEC_IMAGE_AI_SERVICE config-service:MEC_IMAGE_CONFIG_SERVICE"

    local _b="" _r="" _dim=""
    if [ -t 1 ]; then
        _b=$(printf '\033[1m')
        _r=$(printf '\033[0m')
        _dim=$(printf '\033[2m')
    fi

    printf '%s\n' "${_b}Tools${_r}"
    printf '\n'
    printf '%s\n' "${_b}Remote images${_r}${_dim} — mec update <tool> [image:tag] | mec reset <tool>${_r}"
    printf '  %-20s  %s\n' "TOOL" "IMAGE"
    printf '  %-20s  %s\n' "----" "-----"
    for _entry in $_public_tools; do
        local _tool="${_entry%%:*}"
        local _var="${_entry##*:}"
        local _image
        _image=$(eval echo "\${$_var}")
        printf '  %-20s  %s\n' "$_tool" "$_image"
    done

    printf '\n'
    printf '%s\n' "${_b}MEC custom builds${_r}${_dim} — mec update <tool> (pull only)${_r}"
    printf '  %-20s  %s\n' "TOOL" "IMAGE"
    printf '  %-20s  %s\n' "----" "-----"
    for _entry in $_custom_tools; do
        local _tool="${_entry%%:*}"
        local _var="${_entry##*:}"
        local _image
        _image=$(eval echo "\${$_var}")
        printf '  %-20s  %s\n' "$_tool" "$_image"
    done
}

# _mec_validate_public_image <tool> <image>
# Returns 0 if the image contains the expected tool binary with recognizable output.
# Prints a warning and returns 1 on failure — pin is aborted for safety.
_mec_validate_public_image() {
    local _tool="$1"
    local _image="$2"

    # "tool:binary:expected-substring-in-version-output"
    local _validators="aws:aws:aws-cli terraform:terraform:Terraform node:node:v node20:node:v node22:node:v node24:node:v gcloud:gcloud:Google Cloud SDK python:python:Python promptfoo:promptfoo:promptfoo"

    local _binary="" _expected=""
    for _v in $_validators; do
        if [ "${_v%%:*}" = "$_tool" ]; then
            _binary=$(echo "$_v" | cut -d: -f2)
            _expected=$(echo "$_v" | cut -d: -f3-)
            break
        fi
    done

    if [ -z "$_binary" ]; then
        # No validator defined for this tool — skip check
        return 0
    fi

    printf '[mec] Validating image %s contains %s ... ' "$_image" "$_tool" >&2
    local _out
    if ! _out=$(docker run --rm --entrypoint "" "$_image" "$_binary" --version 2>&1); then
        echo "FAILED" >&2
        echo "[mec] WARNING: '$_binary --version' exited non-zero for image: $_image" >&2
        echo "[mec] This image may not contain '$_tool'. Pin aborted for safety." >&2
        return 1
    fi

    if ! echo "$_out" | grep -qi "$_expected"; then
        echo "FAILED" >&2
        echo "[mec] WARNING: Expected '$_expected' in output of '$_binary --version' but got:" >&2
        echo "  $_out" >&2
        echo "[mec] This image may not be a valid '$_tool' image. Pin aborted for safety." >&2
        return 1
    fi

    echo "ok" >&2
    return 0
}

# ----------------------------------------------------------------------------
# Update Command
# ----------------------------------------------------------------------------

mec_update() {
    local _public_tools="aws:MEC_IMAGE_AWS terraform:MEC_IMAGE_TERRAFORM gcloud:MEC_IMAGE_GCLOUD python:MEC_IMAGE_PYTHON node:MEC_IMAGE_NODE node20:MEC_IMAGE_NODE20 node22:MEC_IMAGE_NODE22 node24:MEC_IMAGE_NODE24 promptfoo:MEC_IMAGE_PROMPTFOO"
    local _custom_tools="claude:MEC_IMAGE_CLAUDE dashboard:MEC_IMAGE_DASHBOARD playwright:MEC_IMAGE_PLAYWRIGHT aws-sso-cred:MEC_IMAGE_AWS_SSO_CRED serverless:MEC_IMAGE_SERVERLESS speedtest:MEC_IMAGE_SPEEDTEST yarn-berry:MEC_IMAGE_YARN_BERRY yarn-plus:MEC_IMAGE_YARN_PLUS ai-service:MEC_IMAGE_AI_SERVICE config-service:MEC_IMAGE_CONFIG_SERVICE"
    local _all_tools="$_public_tools $_custom_tools"

    local _target_tool="${1:-}"
    local _target_tag="${2:-}"

    # Validate tool name when a specific tool is given (before any other checks)
    if [ -n "$_target_tool" ]; then
        local _found=0
        for _entry in $_all_tools; do
            if [ "${_entry%%:*}" = "$_target_tool" ]; then
                _found=1
                break
            fi
        done
        if [ "$_found" -eq 0 ]; then
            echo "Unknown tool: $_target_tool" >&2
            echo "Run 'mec list' to see available tools." >&2
            exit 1
        fi
    fi

    # If a tag is given, only allow for Group A tools
    if [ -n "$_target_tool" ] && [ -n "$_target_tag" ]; then
        local _is_public=0
        for _entry in $_public_tools; do
            if [ "${_entry%%:*}" = "$_target_tool" ]; then
                _is_public=1
                break
            fi
        done
        if [ "$_is_public" -eq 0 ]; then
            echo "Cannot pin '$_target_tool': this is a custom my-ez-cli build." >&2
            echo "Custom image version management is tracked in a separate issue." >&2
            echo "To pull the latest published build: mec update $_target_tool" >&2
            exit 1
        fi
        # Validate the image actually contains the expected tool (supply-chain check)
        if ! _mec_validate_public_image "$_target_tool" "$_target_tag"; then
            exit 1
        fi
        # Resolve variable and write pin
        local _var=""
        for _entry in $_public_tools; do
            if [ "${_entry%%:*}" = "$_target_tool" ]; then
                _var="${_entry##*:}"
                break
            fi
        done
        local _user_images="${MEC_HOME}/images.conf"
        mkdir -p "$MEC_HOME"
        if [ -f "$_user_images" ]; then
            (grep -v "^${_var}=" "$_user_images" > "${_user_images}.tmp" || true) && mv "${_user_images}.tmp" "$_user_images"
        fi
        echo "${_var}=${_target_tag}" >> "$_user_images"
        # Re-source user overrides so the pull loop sees the new pin
        # shellcheck disable=SC1090
        . "$_user_images"
        echo "Pinned $_target_tool to $_target_tag"
    fi

    echo "Pulling images..."
    for _entry in $_all_tools; do
        local _tool="${_entry%%:*}"
        local _var="${_entry##*:}"
        if [ -n "$_target_tool" ] && [ "$_tool" != "$_target_tool" ]; then
            continue
        fi
        local _image
        _image=$(eval echo "\${$_var}")
        printf '  Pulling %s ... ' "$_image"
        if docker pull "$_image" >/dev/null 2>&1; then
            echo "done"
        else
            echo "FAILED"
        fi
    done
}

# ----------------------------------------------------------------------------
# Reset Command
# ----------------------------------------------------------------------------

mec_reset() {
    local _tool="${1:-}"
    if [ -z "$_tool" ]; then
        echo "Usage: mec reset <tool>" >&2
        echo "Run 'mec list' to see available tools." >&2
        exit 1
    fi

    local _public_tools="aws:MEC_IMAGE_AWS terraform:MEC_IMAGE_TERRAFORM gcloud:MEC_IMAGE_GCLOUD python:MEC_IMAGE_PYTHON node:MEC_IMAGE_NODE node20:MEC_IMAGE_NODE20 node22:MEC_IMAGE_NODE22 node24:MEC_IMAGE_NODE24 promptfoo:MEC_IMAGE_PROMPTFOO"
    local _custom_tool_names="claude dashboard playwright aws-sso-cred serverless speedtest yarn-berry yarn-plus ai-service config-service"

    # Reject reset for custom-build tools
    for _custom in $_custom_tool_names; do
        if [ "$_custom" = "$_tool" ]; then
            echo "Cannot reset '$_tool': this is a custom my-ez-cli build with no pinnable version." >&2
            echo "Custom image version management is tracked in a separate issue." >&2
            exit 1
        fi
    done

    # Resolve variable for public tools
    local _var=""
    for _entry in $_public_tools; do
        if [ "${_entry%%:*}" = "$_tool" ]; then
            _var="${_entry##*:}"
            break
        fi
    done
    if [ -z "$_var" ]; then
        echo "Unknown tool: $_tool" >&2
        exit 1
    fi

    local _user_images="${MEC_HOME}/images.conf"
    if [ -f "$_user_images" ]; then
        (grep -v "^${_var}=" "$_user_images" > "${_user_images}.tmp" || true) && mv "${_user_images}.tmp" "$_user_images"
    fi
    echo "Reset $_tool to default image"
}

# ----------------------------------------------------------------------------
# Main Dispatch
# ----------------------------------------------------------------------------

COMMAND="${1:-help}"

case "$COMMAND" in
    config)
        shift
        mec_config "${1:---help}" "${@:2}"
        ;;
    ai)
        shift
        mec_ai "${1:---help}" "${@:2}"
        ;;
    telemetry)
        shift
        mec_telemetry "${1:---help}" "${@:2}"
        ;;
    logs)
        shift
        mec_logs "${1:---help}" "${@:2}"
        ;;
    claude)
        shift
        # Intercept 'mec claude firewall' before passing to bin/claude
        if [ "${1:-}" = "firewall" ]; then
            shift
            mec_claude_firewall "$@"
        else
            exec "$SCRIPT_DIR/claude" "$@"
        fi
        ;;
    setup)
        shift
        mec_setup "$@"
        ;;
    install)
        shift
        mec_install "$@"
        ;;
    uninstall)
        shift
        mec_uninstall "$@"
        ;;
    dashboard)
        shift
        mec_dashboard "${1:-help}" "${@:2}"
        ;;
    doctor)
        shift
        mec_doctor "${@}"
        ;;
    purge)
        shift
        mec_purge "$@"
        ;;
    list)
        mec_list
        ;;
    update)
        shift
        mec_update "$@"
        ;;
    reset)
        shift
        mec_reset "$@"
        ;;
    version|--version|-v)
        show_version
        ;;
    help|--help|-h)
        show_help
        ;;
    # Tool wrappers — delegate directly to the corresponding bin/ script
    aws|aws-get-session-token|aws-sso|aws-sso-cred| \
    gcloud|gcloud-login| \
    node|node20|node22|node24| \
    npm|npm20|npm22| \
    npx|npx20|npx22| \
    playwright| \
    promptfoo|promptfoo-server| \
    python| \
    serverless| \
    speedtest| \
    terraform| \
    yarn|yarn-berry|yarn-plus|yarn20|yarn22)
        exec "$SCRIPT_DIR/$COMMAND" "${@:2}"
        ;;
    *)
        echo "Unknown command: $COMMAND" >&2
        echo "Run 'mec help' for usage information" >&2
        exit 1
        ;;
esac
