#!/bin/bash
set -e

# Source common utilities (works with symlinks)
SCRIPT_DIR="$(cd "$(dirname "$([ -L "$0" ] && readlink "$0" || echo "$0")")" && pwd)"
MEC_BASE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
. "${MEC_BASE_DIR}/bin/utils/common.sh"

# Check Docker availability
check_docker

IMAGE=${IMAGE:-"ghcr.io/promptfoo/promptfoo:latest"} # pin a specific version if needed
WORKDIR=/app

# Container naming and labeling
CONTAINER_NAME=$(get_container_name "promptfoo")
CONTAINER_LABELS=$(get_container_labels "promptfoo" "$IMAGE")
PROMPTFOO_CONFIG_DIR=${PROMPTFOO_CONFIG_DIR:-"$WORKDIR/data"} # folder to store promptfoo config and data
PROMPTFOO_REMOTE_API_BASE_URL=${PROMPTFOO_REMOTE_API_BASE_URL:-""} # e.g., http://localhost:33333
PROMPTFOO_REMOTE_APP_BASE_URL=${PROMPTFOO_REMOTE_APP_BASE_URL:-""} # e.g., http://localhost:33333
PROMPTFOO_API_PORT=${PROMPTFOO_API_PORT:-3000} # API and Web UI port

# Model providers API Keys - set only what is needed for your tests
OPENAI_API_KEY=${OPENAI_API_KEY:-""}
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-""}
AZURE_API_KEY=${AZURE_API_KEY:-""}
LITELLM_API_KEY=${LITELLM_API_KEY:-""}
GITHUB_TOKEN=${GITHUB_TOKEN:-""}

# AWS config - for bedrock and bedrock-agent providers
# See: https://www.promptfoo.dev/docs/providers/aws-bedrock/#authentication-options
AWS_REGION=${AWS_REGION:-""}
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID:-""}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY:-""}
AWS_SESSION_TOKEN=${AWS_SESSION_TOKEN:-""} # when using temporary credentials
LANG=${LANG:-"en_US.UTF-8"}

if [ ! -z "$PROMPTFOO_API_PORT" ]; then
    # Default port binding for promptfoo API and UI
    PORTS="-p $PROMPTFOO_API_PORT:$PROMPTFOO_API_PORT"
fi

# Setup logging (if enabled)
setup_logging "promptfoo" "$IMAGE" "promptfoo ${*}"

# Build docker command
DOCKER_CMD="docker run -i $(get_tty_flag) --rm \
    --name $CONTAINER_NAME \
    $CONTAINER_LABELS \
    --volume $PWD:$WORKDIR \
    --volume $PWD/data:$PROMPTFOO_CONFIG_DIR \
    --env API_PORT=$PROMPTFOO_API_PORT \
    --env AWS_REGION=$AWS_REGION \
    --env AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID \
    --env AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY \
    --env AWS_SESSION_TOKEN=$AWS_SESSION_TOKEN \
    --env LANG=$LANG \
    --env PROMPTFOO_CONFIG_DIR=$PROMPTFOO_CONFIG_DIR \
    --env PROMPTFOO_REMOTE_APP_BASE_URL=$PROMPTFOO_REMOTE_APP_BASE_URL \
    --env PROMPTFOO_REMOTE_API_BASE_URL=$PROMPTFOO_REMOTE_API_BASE_URL \
    --env OPENAI_API_KEY=$OPENAI_API_KEY \
    --env ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY \
    --env AZURE_API_KEY=$AZURE_API_KEY \
    --env LITELLM_API_KEY=$LITELLM_API_KEY \
    --env GITHUB_TOKEN=$GITHUB_TOKEN \
    --workdir $WORKDIR \
    --entrypoint promptfoo \
    $PORTS \
    $IMAGE $(printf '%q ' "$@")"

# Execute with AI analysis
exec_with_ai "$DOCKER_CMD"
