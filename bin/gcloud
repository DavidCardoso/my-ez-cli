#!/bin/bash
set -e

# Source common utilities (works with symlinks)
SCRIPT_DIR="$(cd "$(dirname "$([ -L "$0" ] && readlink "$0" || echo "$0")")" && pwd)"
MEC_BASE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
. "${MEC_BASE_DIR}/bin/utils/common.sh"

# Check Docker availability
check_docker

IMAGE=eu.gcr.io/google.com/cloudsdktool/google-cloud-cli:latest
WORKDIR=/app

# Container naming and labeling
CONTAINER_NAME=$(get_container_name "gcloud")
CONTAINER_LABELS=$(get_container_labels "gcloud" "$IMAGE")

# Setup logging (if enabled)
setup_logging "gcloud" "$IMAGE" "gcloud ${*}"

# Build docker command
DOCKER_CMD="docker run --rm \
    --name $CONTAINER_NAME \
    $CONTAINER_LABELS \
    --platform linux/amd64 \
    --volume $PWD:$WORKDIR \
    --volumes-from gcloud-config \
    --workdir $WORKDIR \
    --entrypoint gcloud \
    $IMAGE $(printf '%q ' "$@")"

# Execute with AI analysis
exec_with_ai "$DOCKER_CMD"
