#!/bin/bash
set -e

# Source common utilities (works with symlinks)
SCRIPT_DIR="$(cd "$(dirname "$([ -L "$0" ] && readlink "$0" || echo "$0")")" && pwd)"
MEC_BASE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
. "${MEC_BASE_DIR}/bin/utils/common.sh"

# Check Docker availability
check_docker

# Defaults to NodeJS v22 if no version is specified
IMAGE=${IMAGE:-"node:22-alpine"}
WORKDIR=/app

# Container naming and labeling
CONTAINER_NAME=$(get_container_name "node")
CONTAINER_LABELS=$(get_container_labels "node" "$IMAGE")

# Get port flags from MEC_BIND_PORTS
PORTS=$(get_port_flags)

# Setup logging (if enabled)
setup_logging "node" "$IMAGE" "node ${*}"

# Build docker command
DOCKER_CMD="docker run -i $(get_tty_flag) --rm \
    --name $CONTAINER_NAME \
    $CONTAINER_LABELS \
    --volume $PWD:$WORKDIR \
    --workdir $WORKDIR \
    $PORTS \
    $IMAGE $(printf '%q ' "$@")"

# Execute with AI analysis (port detection)
exec_with_ai "$DOCKER_CMD"
