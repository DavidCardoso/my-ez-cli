#!/bin/bash
set -e

# Source common utilities (works with symlinks)
SCRIPT_DIR="$(cd "$(dirname "$([ -L "$0" ] && readlink "$0" || echo "$0")")" && pwd)"
MEC_BASE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
. "${MEC_BASE_DIR}/bin/utils/common.sh"

# Check Docker availability
check_docker

IMAGE=${IMAGE:-"$MEC_IMAGE_GCLOUD"}
WORKDIR=/app

# Remove previous auth configs
if [[ $(docker ps --all | grep gcloud-config) ]]; then
    echo "Removing previous 'gcloud-config' container..."
    docker rm gcloud-config
fi

# This is used for Terraform CLI
# and others that require authentication to GCP
if [ -z "$CREDENTIALS_FOLDER" ]; then
    CREDENTIALS_FOLDER="$HOME/.config/gcloud"
    mkdir -p $CREDENTIALS_FOLDER
fi

# Container naming and labeling
# Note: Uses static name "gcloud-config" for compatibility with bin/gcloud (--volumes-from)
CONTAINER_LABELS=$(get_container_labels "gcloud-login" "$IMAGE")

# Setup logging (if enabled)
setup_logging "gcloud-login"

# run from your working directory
# shellcheck disable=SC2046  # get_tty_flag intentionally word-splits to pass -t or nothing
docker run -i $(get_tty_flag) \
    --platform linux/amd64 \
    --name gcloud-config \
    $CONTAINER_LABELS \
    --volume $PWD:$WORKDIR \
    --volume $CREDENTIALS_FOLDER:/root/.config/gcloud \
    --workdir $WORKDIR \
    --entrypoint gcloud \
    $IMAGE auth application-default login
