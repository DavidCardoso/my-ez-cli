#!/bin/bash
set -e

# Source common utilities (works with symlinks)
SCRIPT_DIR="$(cd "$(dirname "$([ -L "$0" ] && readlink "$0" || echo "$0")")" && pwd)"
MEC_BASE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
. "${MEC_BASE_DIR}/bin/utils/common.sh"

# Check Docker availability
check_docker

WORKDIR=/app

# see "../docker/serverless/" for more info.
IMAGE=${IMAGE:-"$MEC_IMAGE_SERVERLESS"}

# via env var
if [ -z "${STACK_NAME}" ]; then
    STACK_NAME=development
fi

# Container naming and labeling
CONTAINER_NAME=$(get_container_name "serverless")
CONTAINER_LABELS=$(get_container_labels "serverless" "$IMAGE")

# Setup logging (if enabled)
setup_logging "serverless" "$IMAGE" "serverless ${*}"

# Detect platform (matches build script logic; override with PLATFORM env var)
ARCH=$(uname -m)
case "$ARCH" in
    x86_64)        PLATFORM=${PLATFORM:-linux/amd64} ;;
    aarch64|arm64) PLATFORM=${PLATFORM:-linux/arm64} ;;
    *)             PLATFORM=${PLATFORM:-linux/amd64} ;;
esac

# Build docker command
DOCKER_CMD="docker run -i $(get_tty_flag) --rm \
    --platform $PLATFORM \
    --name $CONTAINER_NAME \
    $CONTAINER_LABELS \
    --env AWS_PROFILE=${AWS_PROFILE} \
    --env AWS_SDK_LOAD_CONFIG=1 \
    --env STACK_NAME=${STACK_NAME} \
    --env SLS_DEBUG="${SLS_DEBUG:-0}" \
    --env DEBUG="${DEBUG:-0}" \
    --volume ${HOME}/.aws:/root/.aws \
    --volume ${PWD}:${WORKDIR} \
    --workdir ${WORKDIR} \
    --entrypoint serverless \
    --network=host \
    ${IMAGE} $(printf '%q ' "$@")"

# Execute with AI analysis
exec_with_ai "$DOCKER_CMD"
